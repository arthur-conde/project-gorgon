<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <IsPackable>false</IsPackable>
    <RootNamespace>Mithril.Tools.MapCalibration.Harness.Tests</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit" />
    <PackageReference Include="xunit.runner.visualstudio" />
    <PackageReference Include="FluentAssertions" />
    <PackageReference Include="Xunit.SkippableFact" />
    <!-- OpenCv native runtime for the production ECC refiner (#978) exercised end-to-end
         by EccRegistrationRefinerTests via the AutoCalibrationEngine integration path. -->
    <PackageReference Include="OpenCvSharp4" />
    <PackageReference Include="OpenCvSharp4.runtime.win" />
  </ItemGroup>
  <ItemGroup>
    <!-- Cross-boundary ProjectReference into the isolated harness lib is fine:
         the lib's PM/targets opt-out is build-local (issue #884 decision). -->
    <ProjectReference Include="..\..\tools\Mithril.MapCalibration.Harness\Mithril.MapCalibration.Harness.csproj" />
    <!-- #978: the production AutoCalibrationEngine + TextureRegistrationRefiner (the
         real ECC seam) under test. Lives here, not in Capture.Tests, because this
         project owns the committed Eltibule frame fixture, the EltibuleReferences
         fixture, and the OpenCv native runtime needed by the full integration path. -->
    <ProjectReference Include="..\..\src\Mithril.MapCalibration.Capture\Mithril.MapCalibration.Capture.csproj" />
    <!-- The DI engine factory (AddMithrilMapCalibrationEngine) for the live-frame repro. -->
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
  </ItemGroup>
  <ItemGroup>
    <!-- Real Eltibule capture frame (#938) — the deterministic regression input for
         EccRegistrationRefinerTests. This is a PG screenshot; kept local to the test,
         not shipped product art. (See PR note: deliberate-regression-input vs. the
         repo's "ship hashes, not PG art" stance is a maintainer call.) -->
    <None Include="Fixtures\*.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>
