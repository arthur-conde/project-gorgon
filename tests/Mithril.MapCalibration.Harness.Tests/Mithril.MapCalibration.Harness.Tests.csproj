<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <IsPackable>false</IsPackable>
    <RootNamespace>Mithril.Tools.MapCalibration.Harness.Tests</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit" />
    <PackageReference Include="xunit.runner.visualstudio" />
    <PackageReference Include="FluentAssertions" />
    <PackageReference Include="Xunit.SkippableFact" />
    <!-- #938 registration prototype: OpenCV phase-correlation / ECC / feature-matching eval. -->
    <PackageReference Include="OpenCvSharp4" />
    <PackageReference Include="OpenCvSharp4.runtime.win" />
  </ItemGroup>
  <ItemGroup>
    <!-- Cross-boundary ProjectReference into the isolated harness lib is fine:
         the lib's PM/targets opt-out is build-local (issue #884 decision). -->
    <ProjectReference Include="..\..\tools\Mithril.MapCalibration.Harness\Mithril.MapCalibration.Harness.csproj" />
    <!-- #978: the production AutoCalibrationEngine + TextureRegistrationRefiner (the
         real ECC seam) under test. Lives here, not in Capture.Tests, because this
         project already owns the committed Eltibule frame fixtures, EltibuleReferences(),
         and the OpenCv native runtime needed by the full integration path. -->
    <ProjectReference Include="..\..\src\Mithril.MapCalibration.Capture\Mithril.MapCalibration.Capture.csproj" />
    <!-- The DI engine factory (AddMithrilMapCalibrationEngine) for the live-frame repro. -->
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
  </ItemGroup>
  <ItemGroup>
    <!-- Real Eltibule capture frames (#938) — the deterministic detect repro inputs.
         These are PG screenshots; kept local to the repro test, not shipped product art. -->
    <None Include="Fixtures\*.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>
