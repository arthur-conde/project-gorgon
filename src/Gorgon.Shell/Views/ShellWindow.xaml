<Window x:Class="Gorgon.Shell.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:vm="clr-namespace:Gorgon.Shell.ViewModels"
        Title="Gorgon" Width="1100" Height="700"
        Background="#FF1A1A1A" Foreground="#FFE8E8E8"
        WindowStartupLocation="Manual">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Gorgon.Shared;component/Wpf/Resources.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Samwise.Module;component/Views/Resources.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Legolas.Module;component/Views/Resources.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Gandalf.Module;component/Views/Resources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <DockPanel>
        <tb:TaskbarIcon x:Name="Tray" DockPanel.Dock="Top" Visibility="Visible"
                        ToolTipText="Gorgon"/>
        <Border DockPanel.Dock="Bottom" Background="#FF252525" Padding="8,4">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" Text="{Binding VersionText}"
                           Foreground="#66FFFFFF" Margin="12,0,0,0"/>
                <TextBlock Text="{Binding StatusText}" Foreground="#88FFFFFF"/>
            </DockPanel>
        </Border>
        <Border DockPanel.Dock="Left" Width="260" Background="#FF202020" BorderThickness="0,0,1,0" BorderBrush="#33FFFFFF">
            <DockPanel>
                <StackPanel DockPanel.Dock="Bottom" Margin="10">
                    <Button Margin="0,0,0,6" Padding="10,6" HorizontalContentAlignment="Left"
                            Command="{Binding OpenDiagnosticsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="pack://application:,,,/Gorgon;component/Resources/diagnostics.ico"
                                   Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Diagnostics" FontSize="{DynamicResource AppFontSizeLarge}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Margin="0,0,0,6" Padding="10,6" HorizontalContentAlignment="Left"
                            Command="{Binding OpenHotkeysCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="pack://application:,,,/Gorgon;component/Resources/hotkeys.ico"
                                   Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Hotkeys" FontSize="{DynamicResource AppFontSizeLarge}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Padding="10,6" HorizontalContentAlignment="Left"
                            Command="{Binding OpenSettingsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="pack://application:,,,/Gorgon;component/Resources/settings.ico"
                                   Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Settings" FontSize="{DynamicResource AppFontSizeLarge}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <!-- Active character chip (click to open character picker) -->
                <ToggleButton DockPanel.Dock="Top" x:Name="CharacterChipToggle" Margin="10,10,10,0"
                              Padding="10,6" HorizontalContentAlignment="Stretch"
                              Background="#FF2A2A2A" BorderBrush="#FF444444">
                    <StackPanel Orientation="Horizontal">
                        <icon:PackIconLucide Kind="User" Width="18" Height="18"
                                             VerticalAlignment="Center" Margin="0,0,8,0"
                                             Foreground="#FFD4A847"/>
                        <StackPanel>
                            <TextBlock Text="{Binding ActiveCharacterName, TargetNullValue='No character'}"
                                       FontSize="{DynamicResource AppFontSizeMedium}" FontWeight="SemiBold"
                                       Foreground="#FFE8E8E8">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasActiveCharacter}" Value="False">
                                                <Setter Property="Text" Value="No character"/>
                                                <Setter Property="Foreground" Value="#88FFFFFF"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding ActiveServer}"
                                       FontSize="{DynamicResource AppFontSizeHint}" Foreground="#66FFFFFF"
                                       Visibility="{Binding HasActiveCharacter, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </StackPanel>
                </ToggleButton>
                <Popup IsOpen="{Binding ElementName=CharacterChipToggle, Path=IsChecked, Mode=TwoWay}"
                       StaysOpen="False" Placement="Bottom" PlacementTarget="{Binding ElementName=CharacterChipToggle}"
                       AllowsTransparency="True">
                    <Border Background="#FF1F1F1F" BorderBrush="#55FFFFFF" BorderThickness="1" Padding="4"
                            MinWidth="240">
                        <StackPanel>
                            <TextBlock Text="Active character"
                                       Foreground="#66FFFFFF" FontSize="{DynamicResource AppFontSizeHint}"
                                       Margin="8,6,8,4"/>
                            <ItemsControl ItemsSource="{Binding AvailableCharacters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button HorizontalContentAlignment="Left" Padding="10,6" Margin="0,0,0,2"
                                                Background="Transparent" BorderThickness="0"
                                                Command="{Binding DataContext.SelectCharacterCommand,
                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Display}" Foreground="#FFE8E8E8"
                                                           FontSize="{DynamicResource AppFontSizeMedium}"/>
                                                <TextBlock Text="{Binding ExportLabel, StringFormat='exported {0}'}"
                                                           Foreground="#66FFFFFF"
                                                           FontSize="{DynamicResource AppFontSizeHint}"
                                                           Visibility="{Binding ExportLabel,
                                                               Converter={StaticResource NullOrEmptyToVis}}"/>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="No character exports found — run /exportcharacter in-game."
                                       Foreground="#88FFFFFF" FontSize="{DynamicResource AppFontSizeHint}"
                                       TextWrapping="Wrap" Margin="8,6"
                                       Visibility="{Binding HasNoCharacters, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Border>
                </Popup>

                <ListBox ItemsSource="{Binding Modules}"
                         SelectedItem="{Binding SelectedModule, Mode=TwoWay}"
                         Background="Transparent" BorderThickness="0" Padding="6">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4,6">
                                <Grid Width="28" Height="28" Margin="0,0,10,0">
                                    <icon:PackIconLucide Kind="{Binding Icon}" Width="22" Height="22"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Visibility="{Binding HasImage, Converter={StaticResource InverseBoolToVis}}"/>
                                    <Image Source="{Binding ImageSource}" Width="28" Height="28"
                                           Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}"/>
                                </Grid>
                                <TextBlock Text="{Binding Title}" FontSize="{DynamicResource AppFontSizeLarge}" VerticalAlignment="Center" Foreground="#FFE8E8E8"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
        <ContentPresenter Content="{Binding ActiveContent}"/>
    </DockPanel>
</Window>
