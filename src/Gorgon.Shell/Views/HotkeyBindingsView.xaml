<UserControl x:Class="Gorgon.Shell.Views.HotkeyBindingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:hk="clr-namespace:Gorgon.Shared.Hotkeys.Controls;assembly=Gorgon.Shared"
             xmlns:vm="clr-namespace:Gorgon.Shell.ViewModels"
             Background="#FF1A1A1A">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Image Source="pack://application:,,,/Gorgon;component/Resources/hotkeys.ico"
                       Width="28" Height="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Hotkeys" FontFamily="Cambria" FontSize="22" FontWeight="SemiBold"
                           Foreground="#FFD4A847" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6,4" Margin="0,0,0,12">
                <TextBox.Resources>
                    <Style TargetType="TextBox">
                        <Setter Property="Background" Value="#FF252525"/>
                        <Setter Property="Foreground" Value="#FFE8E8E8"/>
                        <Setter Property="BorderBrush" Value="#33FFFFFF"/>
                    </Style>
                </TextBox.Resources>
            </TextBox>
        </StackPanel>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding RowsView}">
                <ItemsControl.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" Foreground="#FFD4A847"
                                           FontFamily="Cambria" FontSize="14"
                                           Margin="0,12,0,4"/>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ItemsControl.GroupStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8,6" Margin="0,2" CornerRadius="3"
                                Background="#FF252525" BorderBrush="#22FFFFFF" BorderThickness="1">
                            <DockPanel>
                                <hk:HotkeyChipControl DockPanel.Dock="Right"
                                                      Binding="{Binding Binding, Mode=TwoWay}"
                                                      HotkeyService="{Binding DataContext.HotkeyService, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}" Foreground="#FFE8E8E8"/>
                                    <StackPanel Orientation="Horizontal"
                                               Visibility="{Binding HasConflict, Converter={StaticResource BoolToVis}}">
                                        <icon:PackIconLucide Kind="TriangleAlert" Width="11" Height="11" Foreground="#FFE0A030" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                        <TextBlock Text="{Binding ConflictWith, StringFormat='Conflicts with {0}'}"
                                                   Foreground="#FFE0A030" FontSize="11"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal"
                                               Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                                        <icon:PackIconLucide Kind="X" Width="11" Height="11" Foreground="#FFD04040" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                        <TextBlock Text="{Binding Error}"
                                                   Foreground="#FFD04040" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
