<UserControl x:Class="Gorgon.Shell.Views.SettingsHostView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FF1A1A1A">
    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="⚙ Settings"
                   FontFamily="Cambria" FontSize="20" Foreground="#FFD4A847"
                   Margin="16,12,16,8"/>

        <Border DockPanel.Dock="Left" Width="200" Background="#FF202020"
                BorderThickness="0,0,1,0" BorderBrush="#22FFFFFF">
            <ListBox ItemsSource="{Binding Sections}"
                     SelectedItem="{Binding SelectedSection, Mode=TwoWay}"
                     Background="Transparent" BorderThickness="0" Padding="4">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="4">
                            <TextBlock Text="{Binding Icon}" FontSize="15" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding Title}" VerticalAlignment="Center" Foreground="#FFE8E8E8"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <ContentPresenter Content="{Binding ActiveContent}"/>
    </DockPanel>
</UserControl>
