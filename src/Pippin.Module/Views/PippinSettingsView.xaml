<UserControl x:Class="Pippin.Views.PippinSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Background="#FF1A1A1A">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="720" Margin="24,16" HorizontalAlignment="Left">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Image Source="pack://application:,,,/Pippin.Module;component/Resources/pippin.ico"
                       Width="28" Height="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Pippin · Gourmand Settings"
                           FontFamily="{DynamicResource AppHeaderFontFamily}" FontSize="{DynamicResource AppFontSizeHero}" FontWeight="SemiBold"
                           Foreground="#FFD4A847" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Text="The Gourmand module tracks which foods your character has eaten."
                       Foreground="#CCFFFFFF" TextWrapping="Wrap" Margin="0,0,0,8"/>
            <TextBlock Text="To sync your data, open the Gourmand skill panel in-game and click the 'Foods Eaten' report. The module will automatically parse the log entry."
                       Foreground="#88FFFFFF" TextWrapping="Wrap" Margin="0,0,0,16"/>

            <TextBlock Text="Data is stored at:" Foreground="#88FFFFFF" Margin="0,0,0,4"/>
            <TextBlock Text="%LOCALAPPDATA%\Gorgon\Pippin\gourmand-state.json"
                       Foreground="#55FFFFFF" FontFamily="{DynamicResource AppMonoFontFamily}" FontSize="{DynamicResource AppFontSizeHint}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
