<UserControl x:Class="Celebrimbor.Views.WizardStepIndicator"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <!-- Strip every bit of default Button chrome so only the inner Border (step badge) shows. -->
            <Style x:Key="ChromelessButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
        <!-- Step 1: Pick Recipes -->
        <Button Command="{Binding GoToPickerCommand}" Style="{StaticResource ChromelessButton}">
            <Border Padding="14,5" CornerRadius="3"
                    BorderThickness="1.5"
                    BorderBrush="{Binding CurrentView, Converter={StaticResource PickerAccent}}">
                <StackPanel Orientation="Horizontal">
                    <Border Width="20" Height="20" CornerRadius="3" VerticalAlignment="Center" Margin="0,0,6,0"
                            Background="{Binding CurrentView, Converter={StaticResource PickerAccent}}">
                        <TextBlock Text="1" FontWeight="SemiBold" Foreground="#FF1A1A1A"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Pick Recipes" VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="{Binding CurrentView, Converter={StaticResource PickerAccent}}"/>
                </StackPanel>
            </Border>
        </Button>

        <!-- Connector -->
        <Border Width="40" Height="1.5" Margin="6,0" VerticalAlignment="Center"
                Background="#33FFFFFF"/>

        <!-- Step 2: Shopping List -->
        <Button Command="{Binding GoToShoppingCommand}">
            <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource ChromelessButton}">
                    <Setter Property="Opacity" Value="1"/>
                    <Style.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
            <Border Padding="14,5" CornerRadius="3"
                    BorderThickness="1.5"
                    BorderBrush="{Binding CurrentView, Converter={StaticResource ShoppingAccent}}">
                <StackPanel Orientation="Horizontal">
                    <Border Width="20" Height="20" CornerRadius="3" VerticalAlignment="Center" Margin="0,0,6,0"
                            Background="{Binding CurrentView, Converter={StaticResource ShoppingAccent}}">
                        <TextBlock Text="2" FontWeight="SemiBold" Foreground="#FF1A1A1A"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Shopping List" VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="{Binding CurrentView, Converter={StaticResource ShoppingAccent}}"/>
                </StackPanel>
            </Border>
        </Button>
    </StackPanel>
</UserControl>
