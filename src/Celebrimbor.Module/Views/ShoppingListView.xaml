<UserControl x:Class="Celebrimbor.Views.ShoppingListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wpf="clr-namespace:Mithril.Shared.Wpf;assembly=Mithril.Shared"
             mc:Ignorable="d"
             Background="#FF1A1A1A">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel Margin="12">
        <!-- Header -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <Button DockPanel.Dock="Left" Padding="10,4" Command="{Binding BackCommand}" Margin="0,0,10,0"
                    ToolTip="Return to the recipe picker">
                <StackPanel Orientation="Horizontal">
                    <icon:PackIconLucide Kind="ArrowLeft" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="Back" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button DockPanel.Dock="Right" Padding="10,4" Command="{Binding RefreshCommand}"
                    ToolTip="Re-scan the Reports folder for the latest storage export">
                <StackPanel Orientation="Horizontal">
                    <icon:PackIconLucide Kind="RefreshCw" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="Refresh on-hand" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Shopping list" FontFamily="{DynamicResource AppHeaderFontFamily}"
                           FontSize="{DynamicResource AppFontSizeHero}" FontWeight="SemiBold"
                           Foreground="#FFD4A847" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <Border Background="#FF2A2A2A" BorderBrush="#55FFFFFF" BorderThickness="1"
                        CornerRadius="4" Padding="8,3" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Craft-ready: " Foreground="#AAFFFFFF" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CraftReadyItems}" Foreground="#FF7FB069" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text=" / " Foreground="#55FFFFFF" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalItems}" Foreground="#FFE8E8E8" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </DockPanel>

        <!-- Making recap: top context anchor — always visible while scrolling the step ladder below. -->
        <Border DockPanel.Dock="Top" Background="#FF242424" BorderBrush="#33D4A847" BorderThickness="1"
                CornerRadius="4" Padding="10,8" Margin="0,0,0,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                    <icon:PackIconLucide Kind="Hammer" Width="14" Height="14" Foreground="#FFD4A847" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="Making" Foreground="#FFD4A847" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" MaxHeight="90">
                    <ItemsControl ItemsSource="{Binding MakingItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FF1F1F1F" BorderBrush="#33FFFFFF" BorderThickness="1"
                                        CornerRadius="4" Padding="6,4" Margin="0,0,6,6">
                                    <StackPanel Orientation="Vertical">
                                        <!-- Recipe card tooltip is scoped to just the icon/name/quantity row,
                                             so it doesn't compete with the per-item inspect tooltips below. -->
                                        <StackPanel Orientation="Horizontal"
                                                    ToolTipService.InitialShowDelay="{Binding DataContext.TooltipDelayMs, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    ToolTipService.BetweenShowDelay="0">
                                            <StackPanel.ToolTip>
                                                <ToolTip Background="Transparent" BorderThickness="0" Padding="0"
                                                         Content="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                                         ContentTemplate="{StaticResource RecipeCardTemplate}"/>
                                            </StackPanel.ToolTip>
                                            <wpf:IconImage IconId="{Binding IconId}" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding DisplayName}" Foreground="#FFE8E8E8" VerticalAlignment="Center" MaxWidth="180" TextTrimming="CharacterEllipsis"/>
                                            <Border Margin="6,0,0,0" Padding="5,1" CornerRadius="3" Background="#FFD4A847" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Quantity}" Foreground="#FF1A1A1A" FontWeight="SemiBold" FontSize="11"/>
                                            </Border>
                                        </StackPanel>
                                        <ItemsControl Margin="0,4,0,0"
                                                      ItemsSource="{Binding InspectableItems}"
                                                      Visibility="{Binding HasInspectableItem, Converter={StaticResource BoolToVis}}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Command="{Binding DataContext.OpenItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding InternalName}"
                                                            Cursor="Hand" Padding="0" Margin="0,0,3,0"
                                                            Background="Transparent" BorderThickness="0"
                                                            ToolTipService.InitialShowDelay="{Binding DataContext.TooltipDelayMs, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            ToolTipService.BetweenShowDelay="0">
                                                        <Button.ToolTip>
                                                            <ToolTip Background="Transparent" BorderThickness="0" Padding="0"
                                                                     Content="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                                <ToolTip.ContentTemplate>
                                                                    <DataTemplate>
                                                                        <Border Background="#FF2A2A2A" BorderBrush="#55FFFFFF" BorderThickness="1"
                                                                                CornerRadius="4" Padding="10" MaxWidth="320">
                                                                            <DockPanel>
                                                                                <wpf:IconImage DockPanel.Dock="Left" IconId="{Binding IconId}"
                                                                                               Width="40" Height="40" Margin="0,0,10,0" VerticalAlignment="Top"/>
                                                                                <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                                                                           Foreground="#FFD4A847" FontSize="{DynamicResource AppFontSizeLarge}"
                                                                                           TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                                            </DockPanel>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ToolTip.ContentTemplate>
                                                            </ToolTip>
                                                        </Button.ToolTip>
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="Bd" Background="Transparent"
                                                                        Padding="1" CornerRadius="2">
                                                                    <ContentPresenter/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                        <wpf:IconImage IconId="{Binding IconId}" Width="18" Height="18"/>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Status -->
        <Border DockPanel.Dock="Bottom" Margin="0,8,0,0" Padding="4">
            <TextBlock Text="{Binding HeaderStatus}" Foreground="#88FFFFFF" FontSize="{DynamicResource AppFontSizeHint}"/>
        </Border>

        <!-- Ingredient list — ItemsControl with a shared column layout (no selection model) -->
        <Border Background="#FF1F1F1F" BorderBrush="#33FFFFFF" BorderThickness="1">
            <DockPanel>
                <!-- Column header -->
                <Border DockPanel.Dock="Top" Background="#FF2A2A2A" BorderBrush="#33FFFFFF" BorderThickness="0,0,0,1" Padding="8,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="240"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Item" Foreground="#AAFFFFFF" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="Needed" Foreground="#AAFFFFFF" FontWeight="SemiBold" HorizontalAlignment="Right" Padding="0,0,6,0"/>
                        <TextBlock Grid.Column="2" Text="On hand" Foreground="#AAFFFFFF" FontWeight="SemiBold" HorizontalAlignment="Right" Padding="0,0,6,0"/>
                        <TextBlock Grid.Column="3" Text="" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="Override" Foreground="#AAFFFFFF" FontWeight="SemiBold" HorizontalAlignment="Right" Padding="0,0,6,0"/>
                        <TextBlock Grid.Column="5" Text="Remaining" Foreground="#AAFFFFFF" FontWeight="SemiBold" HorizontalAlignment="Right" Padding="0,0,6,0"/>
                    </Grid>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Steps}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Crafting step (dependency depth) -->
                                <StackPanel Margin="0,0,0,6">
                                    <!-- Step header -->
                                    <Button Command="{Binding ToggleExpandedCommand}" HorizontalContentAlignment="Stretch"
                                            Background="Transparent" BorderThickness="0" Padding="0" Focusable="False"
                                            FocusVisualStyle="{x:Null}" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="#FF1A1A1A" Padding="8,6" BorderBrush="#55D4A847" BorderThickness="0,0,0,2">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#FF1F1F1F"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right" Foreground="#AAFFFFFF" FontSize="{DynamicResource AppFontSizeHint}" VerticalAlignment="Center">
                                                <Run Text="{Binding CraftReadyCount, Mode=OneWay}"/>
                                                <Run Text=" / "/>
                                                <Run Text="{Binding TotalCount, Mode=OneWay}"/>
                                                <Run Text=" ready"/>
                                            </TextBlock>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                                                <icon:PackIconLucide Width="14" Height="14" Foreground="#AAFFFFFF" VerticalAlignment="Center" Margin="0,0,8,0">
                                                    <icon:PackIconLucide.Style>
                                                        <Style TargetType="icon:PackIconLucide">
                                                            <Setter Property="Kind" Value="ChevronDown"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                                                    <Setter Property="Kind" Value="ChevronRight"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </icon:PackIconLucide.Style>
                                                </icon:PackIconLucide>
                                                <TextBlock Text="{Binding Label}" FontWeight="SemiBold" FontSize="{DynamicResource AppFontSizeLarge}"
                                                           Foreground="#FFD4A847" VerticalAlignment="Center"/>
                                                <Border Margin="10,0,0,0" Padding="6,2" CornerRadius="3" Background="#447FB069" VerticalAlignment="Center"
                                                        Visibility="{Binding IsComplete, Converter={StaticResource CountToVisibility}}">
                                                    <TextBlock Text="Complete" Foreground="#FF7FB069" FontSize="10" FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                        </DockPanel>
                                    </Button>
                                    <ProgressBar Height="4" Minimum="0" Maximum="100" Value="{Binding ProgressPct, Mode=OneWay}"
                                                 Foreground="#FFD4A847" Background="#FF1A1A1A" BorderThickness="0"/>

                                    <!-- Step body — PrimaryTag groups within this step -->
                                    <ItemsControl ItemsSource="{Binding Groups}"
                                                  Visibility="{Binding IsExpanded, Converter={StaticResource CountToVisibility}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <!-- Group (PrimaryTag) -->
                                                <StackPanel>
                                    <!-- Group header: click-to-toggle, shows name / count / ready-progress.
                                         Hidden when the step has only one group — step header already provides context. -->
                                    <Button Command="{Binding ToggleExpandedCommand}" HorizontalContentAlignment="Stretch"
                                            Background="Transparent" BorderThickness="0" Padding="0" Focusable="False"
                                            FocusVisualStyle="{x:Null}" Cursor="Hand"
                                            Visibility="{Binding IsHeaderVisible, Converter={StaticResource CountToVisibility}}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="#FF2A2A2A" Padding="8,4" BorderBrush="#33FFFFFF" BorderThickness="0,0,0,1">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#FF323232"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right" Foreground="#88FFFFFF" FontSize="{DynamicResource AppFontSizeHint}" VerticalAlignment="Center">
                                                <Run Text="{Binding CraftReadyCount, Mode=OneWay}"/>
                                                <Run Text=" / "/>
                                                <Run Text="{Binding TotalCount, Mode=OneWay}"/>
                                                <Run Text=" ready"/>
                                            </TextBlock>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                                                <!-- Chevron: down when expanded, right when collapsed -->
                                                <icon:PackIconLucide Width="12" Height="12" Foreground="#88FFFFFF"
                                                                     VerticalAlignment="Center" Margin="0,0,6,0">
                                                    <icon:PackIconLucide.Style>
                                                        <Style TargetType="icon:PackIconLucide">
                                                            <Setter Property="Kind" Value="ChevronDown"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                                                    <Setter Property="Kind" Value="ChevronRight"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </icon:PackIconLucide.Style>
                                                </icon:PackIconLucide>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#FFD4A847" VerticalAlignment="Center"/>
                                                <TextBlock Text=" · " Foreground="#55FFFFFF" Margin="2,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding TotalCount, StringFormat={}{0} items}" Foreground="#88FFFFFF" VerticalAlignment="Center"/>
                                                <Border Margin="8,0,0,0" Padding="6,2" CornerRadius="3" Background="#447FB069" VerticalAlignment="Center"
                                                        Visibility="{Binding IsComplete, Converter={StaticResource CountToVisibility}}">
                                                    <TextBlock Text="Complete" Foreground="#FF7FB069" FontSize="10" FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                        </DockPanel>
                                    </Button>
                                    <ProgressBar Height="3" Minimum="0" Maximum="100" Value="{Binding ProgressPct, Mode=OneWay}"
                                                 Foreground="#FF7FB069" Background="#FF1F1F1F" BorderThickness="0"
                                                 Visibility="{Binding IsHeaderVisible, Converter={StaticResource CountToVisibility}}"/>

                                    <!-- Group rows — auto-collapsed when the group is complete; click header to toggle. -->
                                    <ItemsControl ItemsSource="{Binding Rows}"
                                                  Visibility="{Binding AreRowsVisible, Converter={StaticResource CountToVisibility}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                <Border BorderBrush="#22FFFFFF" BorderThickness="0,0,0,1" Padding="8,4" MinHeight="32">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FF1F1F1F"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#FF242424"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" MinWidth="240"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                            <wpf:IconNameCell IconId="{Binding IconId}" DisplayName="{Binding DisplayName}" VerticalAlignment="Center"/>
                                            <TextBlock Foreground="#88FFFFFF" FontSize="{DynamicResource AppFontSizeHint}"
                                                       FontStyle="Italic" VerticalAlignment="Center" Margin="6,0,0,0"
                                                       Text="{Binding KeywordsLabel, StringFormat=({0})}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding KeywordsLabel}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding TotalNeeded}" Foreground="#FFE8E8E8" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="0,0,6,0"/>
                                        <TextBlock Grid.Column="2" Text="{Binding OnHandDetected}" Foreground="{Binding OnHandDetected, Converter={StaticResource ZeroToGhost}}" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="0,0,6,0"/>

                                        <!-- Location pin — click to open the Sources window with on-hand breakdown + acquisition hints. -->
                                        <Button Grid.Column="3" Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                                                Visibility="{Binding Locations.Count, Converter={StaticResource CountToVisibility}}"
                                                ToolTip="View sources"
                                                Command="{Binding DataContext.ShowSourcesCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <icon:PackIconLucide Kind="MapPin" Width="12" Height="12"
                                                                 Foreground="#FFD4A847"
                                                                 VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Button>

                                        <TextBox Grid.Column="4"
                                                 Text="{Binding Override, UpdateSourceTrigger=LostFocus, TargetNullValue=''}"
                                                 Background="#FF2A2A2A" Foreground="#FFE8E8E8" BorderBrush="#33FFFFFF"
                                                 TextAlignment="Right" Padding="4,2" Margin="2,0" VerticalContentAlignment="Center"
                                                 HorizontalAlignment="Stretch"/>
                                        <TextBlock Grid.Column="5" Text="{Binding Remaining}"
                                                   Foreground="{Binding IsCraftReady, Converter={StaticResource CraftReadyBrush}}"
                                                   FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="0,0,6,0"/>
                                    </Grid>
                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </DockPanel>
</UserControl>
