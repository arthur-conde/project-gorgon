<UserControl x:Class="Celebrimbor.Views.CelebrimborSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Background="#FF1A1A1A">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16" MaxWidth="720" HorizontalAlignment="Left">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Image Source="pack://application:,,,/Celebrimbor.Module;component/Resources/celebrimbor.ico"
                       Width="28" Height="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Celebrimbor · Crafting Settings"
                           FontFamily="{DynamicResource AppHeaderFontFamily}" FontSize="{DynamicResource AppFontSizeHero}" FontWeight="SemiBold"
                           Foreground="#FFD4A847" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Text="Filters" Foreground="#88FFFFFF" Margin="0,0,0,6" FontWeight="SemiBold"/>
            <CheckBox Content="Show known recipes only"
                      IsChecked="{Binding Settings.KnownRecipesOnly}"
                      Foreground="#FFE8E8E8" Margin="0,0,0,4"/>
            <CheckBox Content="Hide recipes above the active character's skill level"
                      IsChecked="{Binding Settings.EnforceSkillLevel}"
                      Foreground="#FFE8E8E8" Margin="0,0,0,4"/>

            <TextBlock Text="Sub-recipe expansion" Foreground="#88FFFFFF" Margin="0,16,0,6" FontWeight="SemiBold"/>
            <TextBlock TextWrapping="Wrap" Foreground="#88FFFFFF" FontSize="{DynamicResource AppFontSizeHint}" Margin="0,0,0,8">
                When an ingredient is itself a recipe (e.g. Butter), expand it into its own ingredients.
                Depth 0 leaves the ingredient as-is; higher depths recurse that many levels with cycle protection.
            </TextBlock>
            <DockPanel LastChildFill="False">
                <TextBlock Text="Depth" VerticalAlignment="Center" Foreground="#FFE8E8E8" Width="60"/>
                <TextBox Width="70" Margin="4,0" Padding="6,4"
                         Text="{Binding Settings.ExpansionDepth, UpdateSourceTrigger=LostFocus}"/>
                <TextBlock Text="levels (0 = off)" VerticalAlignment="Center" Foreground="#88FFFFFF" Margin="6,0,0,0"/>
            </DockPanel>

            <TextBlock Text="Tooltip delay" Foreground="#88FFFFFF" Margin="0,16,0,6" FontWeight="SemiBold"/>
            <TextBlock TextWrapping="Wrap" Foreground="#88FFFFFF" FontSize="{DynamicResource AppFontSizeHint}" Margin="0,0,0,8">
                Milliseconds before a recipe tooltip appears on hover. 0 shows instantly; WPF's default is 400.
            </TextBlock>
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Foreground="#88FFFFFF" Width="80"
                           Text="{Binding Settings.TooltipDelayMs, StringFormat={}{0} ms}"/>
                <Slider Minimum="0" Maximum="2000" SmallChange="50" LargeChange="100" TickFrequency="100"
                        IsSnapToTickEnabled="False" VerticalAlignment="Center" Margin="0,0,8,0"
                        Value="{Binding Settings.TooltipDelayMs}"/>
            </DockPanel>

            <TextBlock Margin="0,24,0,0" TextWrapping="Wrap" Foreground="#66FFFFFF" FontSize="{DynamicResource AppFontSizeHint}">
                Settings, craft list, and per-item overrides persist to %LOCALAPPDATA%\Gorgon\Celebrimbor\settings.json.
            </TextBlock>
        </StackPanel>
    </ScrollViewer>
</UserControl>
