<Window x:Class="Celebrimbor.Views.AugmentPoolView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Celebrimbor.ViewModels"
        xmlns:ref="clr-namespace:Mithril.Shared.Reference;assembly=Mithril.Shared"
        xmlns:wpf="clr-namespace:Mithril.Shared.Wpf;assembly=Mithril.Shared"
        Title="{Binding SourceLabel}"
        Width="780" Height="720"
        MinWidth="520" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="{DynamicResource AppFontFamily}"
        FontSize="{DynamicResource AppFontSize}"
        Background="#FF1A1A1A">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Mithril.Shared;component/Wpf/Resources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <wpf:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <wpf:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
            <wpf:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVis"/>

            <!-- One card per power. Header is always visible (suffix + skill, ranges, floor preview);
                 expander reveals the per-tier breakdown. -->
            <DataTemplate x:Key="AugmentCardTemplate" DataType="{x:Type ref:GroupedAugmentOption}">
                <Border Background="{DynamicResource BgSurfaceBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="1" CornerRadius="4" Margin="0,0,0,6">
                    <Expander Background="Transparent" BorderThickness="0" Padding="10,8">
                        <Expander.Header>
                            <StackPanel HorizontalAlignment="Stretch">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding Skill}"
                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                               FontSize="{DynamicResource AppFontSizeHint}"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"/>
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="Bold"
                                               Foreground="{DynamicResource AccentBrush}"
                                               FontSize="{DynamicResource AppFontSizeLarge}"
                                               TextWrapping="Wrap"/>
                                </DockPanel>
                                <TextBlock Text="{Binding RangesLine}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="{DynamicResource AppFontSizeHint}"
                                           Margin="0,2,0,0"/>
                                <ItemsControl ItemsSource="{Binding FloorEffectLines}"
                                              ItemTemplate="{StaticResource EffectLineTemplate}"
                                              Margin="0,4,0,0"/>
                            </StackPanel>
                        </Expander.Header>
                        <!-- Per-tier breakdown — reveals when the card is expanded. -->
                        <ItemsControl ItemsSource="{Binding Tiers}" Margin="0,8,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource BorderSubtleBrush}"
                                            BorderThickness="0,1,0,0" Padding="0,4,0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding TierLabel}"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       FontSize="{DynamicResource AppFontSizeHint}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Top"/>
                                            <TextBlock Grid.Column="1" Text="{Binding LevelLabel}"
                                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                                       FontSize="{DynamicResource AppFontSizeHint}"
                                                       VerticalAlignment="Top"/>
                                            <ItemsControl Grid.Column="2"
                                                          ItemsSource="{Binding EffectLines}"
                                                          ItemTemplate="{StaticResource EffectLineTemplate}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>
                </Border>
            </DataTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <Border BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="6">
        <DockPanel>
            <!-- Header -->
            <Border DockPanel.Dock="Top" Background="#FF202020" Padding="14,10" CornerRadius="6,6,0,0">
                <StackPanel>
                    <TextBlock Text="{Binding SourceLabel}" FontWeight="Bold"
                               FontFamily="{DynamicResource AppHeaderFontFamily}"
                               FontSize="{DynamicResource AppFontSizeXLarge}" Foreground="#FFD4A847"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding Subtitle}" Foreground="#88FFFFFF"
                               FontSize="{DynamicResource AppFontSizeHint}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Query bar — schema fed directly from the VM since there's no DataGrid here. -->
            <Border DockPanel.Dock="Top" Padding="14,8" Background="#FF252525">
                <StackPanel>
                    <wpf:MithrilQueryBox Schema="{x:Static vm:AugmentPoolViewModel.SchemaSnapshot}"
                                         QueryText="{Binding QueryText, Mode=TwoWay}"
                                         Watermark="bare text, or e.g. Tier &gt;= 5 AND Skill = 'Archery'"/>
                    <TextBlock Text="{Binding QueryError}"
                               Foreground="#FFD96A6A"
                               FontSize="{DynamicResource AppFontSizeHint}"
                               FontStyle="Italic"
                               Margin="0,4,0,0"
                               Visibility="{Binding QueryError, Converter={StaticResource NullOrEmptyToVis}}"/>
                </StackPanel>
            </Border>

            <!-- Footer -->
            <Border DockPanel.Dock="Bottom" Padding="14,8" Background="#FF202020" CornerRadius="0,0,6,6">
                <Button DockPanel.Dock="Right" HorizontalAlignment="Right"
                        Padding="10,3" Content="Close" Click="CloseButton_Click"/>
            </Border>

            <!-- Loading overlay -->
            <Border Padding="14,12"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Expanding pool…" Foreground="#88FFFFFF"
                           FontStyle="Italic"
                           FontSize="{DynamicResource AppFontSizeHint}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- Pool — one card per power, expanders for per-tier detail. Virtualized so 1500-power
                 profiles don't blow up render time on first paint. -->
            <ItemsControl ItemsSource="{Binding Groups}"
                          ItemTemplate="{StaticResource AugmentCardTemplate}"
                          ScrollViewer.CanContentScroll="True"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                          VirtualizingStackPanel.ScrollUnit="Pixel"
                          Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVis}}">
                <ItemsControl.Template>
                    <ControlTemplate TargetType="ItemsControl">
                        <ScrollViewer Padding="14,8"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto"
                                      CanContentScroll="True">
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </ControlTemplate>
                </ItemsControl.Template>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </DockPanel>
    </Border>
</Window>
