<UserControl x:Class="Palantir.Views.LiveInventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wpf="clr-namespace:Mithril.Shared.Wpf;assembly=Mithril.Shared.Wpf"
             xmlns:local="clr-namespace:Palantir.Views"
             mc:Ignorable="d"
             Background="Transparent">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Mithril.Shared.Wpf;component/Resources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <local:InventoryDisplayNameConverter x:Key="DisplayNameConv"/>
            <local:InventoryIconIdConverter x:Key="IconIdConv"/>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel Margin="0,8,0,0">
        <!-- Counts strip + query box -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Background="#FF252525" CornerRadius="3" Padding="8,3" Margin="0,0,6,0">
                    <TextBlock Foreground="#FFE8E8E8" FontFamily="{DynamicResource AppMonoFontFamily}">
                        <Run Text="Items "/><Run Text="{Binding LiveCount, Mode=OneWay}" Foreground="#FFD4A847"/>
                    </TextBlock>
                </Border>
                <Border Background="#FF252525" CornerRadius="3" Padding="8,3" Margin="0,0,6,0"
                        Visibility="{Binding ShowDeleted, Converter={StaticResource BoolToVis}}">
                    <TextBlock Foreground="#FFE8E8E8" FontFamily="{DynamicResource AppMonoFontFamily}">
                        <Run Text="Deleted "/><Run Text="{Binding DeletedCount, Mode=OneWay}" Foreground="#FF888888"/>
                    </TextBlock>
                </Border>
                <CheckBox Content="Show deleted" IsChecked="{Binding ShowDeleted}"
                          Foreground="#AAFFFFFF" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <Button Content="Refresh" Command="{Binding RefreshCommand}"
                        Padding="8,3" VerticalAlignment="Center"/>
            </StackPanel>
            <wpf:MithrilQueryBox Grid="{Binding ElementName=InventoryGrid}"
                                QueryText="{Binding QueryText, Mode=TwoWay}"
                                Watermark="bare text, or e.g. IsRemoved = false AND StackSize >= 5"/>
        </DockPanel>

        <!-- Status hint -->
        <Border DockPanel.Dock="Bottom" Margin="0,8,0,0" Padding="4">
            <TextBlock Foreground="#66FFFFFF" FontSize="{DynamicResource AppFontSizeHint}"
                       Text="Arda L4 inventory accumulator. Retains soft-deleted items. Refreshes on every add/remove/stack-change event."/>
        </Border>

        <wpf:MithrilDataGrid x:Name="InventoryGrid"
                            ItemsSource="{Binding Items}"
                            QueryText="{Binding QueryText, Mode=TwoWay}"
                            Mode="ReadOnly">
            <wpf:MithrilDataGrid.Columns>
                <DataGridTemplateColumn Header="Name" Width="*" MinWidth="220" SortMemberPath="InternalName">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <wpf:IconNameCell>
                                <wpf:IconNameCell.IconId>
                                    <MultiBinding Converter="{StaticResource IconIdConv}">
                                        <Binding Path="InternalName"/>
                                        <Binding Path="DataContext.ReferenceData"
                                                 RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                    </MultiBinding>
                                </wpf:IconNameCell.IconId>
                                <wpf:IconNameCell.DisplayName>
                                    <MultiBinding Converter="{StaticResource DisplayNameConv}">
                                        <Binding Path="InternalName"/>
                                        <Binding Path="DataContext.ReferenceData"
                                                 RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                    </MultiBinding>
                                </wpf:IconNameCell.DisplayName>
                            </wpf:IconNameCell>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Stack" Binding="{Binding StackSize}" SortMemberPath="StackSize" Width="60">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="FontFamily" Value="{DynamicResource AppMonoFontFamily}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="State" Binding="{Binding IsRemoved, Converter={local:RemovedStateConverter}}"
                                    wpf:MithrilDataGrid.QueryName="IsRemoved"
                                    SortMemberPath="IsRemoved" Width="70">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRemoved}" Value="True">
                                    <Setter Property="Foreground" Value="#FF888888"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsRemoved}" Value="False">
                                    <Setter Property="Foreground" Value="#FF6ABF69"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Internal name" Binding="{Binding InternalName}" SortMemberPath="InternalName" Width="180">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#AAFFFFFF"/>
                            <Setter Property="FontFamily" Value="{DynamicResource AppMonoFontFamily}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Instance ID" Binding="{Binding InstanceId}" SortMemberPath="InstanceId" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="FontFamily" Value="{DynamicResource AppMonoFontFamily}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </wpf:MithrilDataGrid.Columns>
            <wpf:MithrilDataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource MithrilDataGridRowStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRemoved}" Value="True">
                            <Setter Property="Opacity" Value="0.45"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </wpf:MithrilDataGrid.RowStyle>
        </wpf:MithrilDataGrid>
    </DockPanel>
</UserControl>
