<UserControl x:Class="Mithril.Shell.Views.AppearanceSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Background="#FF1A1A1A">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Mithril.Shared;component/Wpf/Resources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="640" HorizontalAlignment="Left">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Image Source="pack://application:,,,/Mithril;component/Resources/appearance.ico"
                       Width="28" Height="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Appearance" FontFamily="{DynamicResource AppHeaderFontFamily}" FontSize="{DynamicResource AppFontSizeTitle}" Foreground="#FFD4A847" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Text="UI font" Foreground="#88FFFFFF" Margin="0,0,0,4" FontWeight="SemiBold"/>
            <TextBlock TextWrapping="Wrap" Foreground="#88FFFFFF" FontSize="{DynamicResource AppFontSizeHint}" Margin="0,0,0,6"
                       Text="Applies to body text, controls, and grids. Module headers and monospace fields keep their distinct typefaces."/>
            <ComboBox ItemsSource="{Binding AvailableFonts}"
                      SelectedItem="{Binding Settings.UiFontFamily, Mode=TwoWay}"
                      IsEditable="True"
                      Width="280" HorizontalAlignment="Left" Margin="0,0,0,16"/>

            <TextBlock Text="Font size" Foreground="#88FFFFFF" Margin="0,0,0,4" FontWeight="SemiBold"/>
            <TextBlock TextWrapping="Wrap" Foreground="#88FFFFFF" FontSize="{DynamicResource AppFontSizeHint}" Margin="0,0,0,6"
                       Text="Base size for body text. All other sizes scale proportionally."/>
            <DockPanel Width="420" HorizontalAlignment="Left" Margin="0,0,0,8">
                <TextBlock DockPanel.Dock="Right" Width="48" TextAlignment="Right"
                           Text="{Binding Settings.UiFontSize, StringFormat={}{0:F1} pt}"
                           Foreground="#FFE8E8E8" VerticalAlignment="Center" Margin="8,0,0,0"/>
                <Slider Minimum="{Binding MinFontSize}"
                        Maximum="{Binding MaxFontSize}"
                        Value="{Binding Settings.UiFontSize, Mode=TwoWay}"
                        TickFrequency="1" IsSnapToTickEnabled="False"
                        SmallChange="0.5" LargeChange="1"
                        VerticalAlignment="Center"/>
            </DockPanel>

            <TextBlock Text="Developer mode" Foreground="#88FFFFFF" Margin="0,24,0,4" FontWeight="SemiBold"/>
            <TextBlock TextWrapping="Wrap" Foreground="#88FFFFFF" FontSize="{DynamicResource AppFontSizeHint}" Margin="0,0,0,6"
                       Text="Show developer/diagnostic modules in the sidebar (e.g. live inventory inspector). Off by default."/>
            <CheckBox Content="Enable developer mode"
                      IsChecked="{Binding Settings.DeveloperMode, Mode=TwoWay}"
                      Foreground="#FFE8E8E8"/>

            <TextBlock Margin="0,24,0,0" TextWrapping="Wrap" Foreground="#66FFFFFF" FontSize="{DynamicResource AppFontSizeHint}"
                       Text="Changes preview live. Settings persist on shutdown."/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
