<UserControl x:Class="Mithril.Shell.Views.DiagnosticsSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Background="#FF1A1A1A">
    <UserControl.Resources>
        <ResourceDictionary Source="pack://application:,,,/Mithril.Shared;component/Wpf/Converters.xaml"/>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16" MaxWidth="640" HorizontalAlignment="Left">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <icon:PackIconLucide Kind="Activity" Width="22" Height="22"
                                     VerticalAlignment="Center" Margin="0,0,10,0"
                                     Foreground="#FFD4A847"/>
                <TextBlock Text="Diagnostics"
                           FontFamily="{DynamicResource AppHeaderFontFamily}"
                           FontSize="{DynamicResource AppFontSizeHero}" FontWeight="SemiBold"
                           Foreground="#FFD4A847" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Text="Performance trace" Foreground="#88FFFFFF" Margin="0,0,0,4" FontWeight="SemiBold"/>
            <TextBlock TextWrapping="Wrap" Foreground="#88FFFFFF"
                       FontSize="{DynamicResource AppFontSizeHint}" Margin="0,0,0,8"
                       Text="Records frame timing, the WPF dispatcher queue, GC pressure, binding errors, and module-activation costs to a JSON-lines file. Used to investigate UI sluggishness — leave off unless you're collecting a trace."/>

            <CheckBox Content="Enable perf-trace harness"
                      IsChecked="{Binding Settings.EnablePerfTrace, Mode=TwoWay}"
                      Foreground="#FFE8E8E8" Margin="0,0,0,8"/>

            <CheckBox Content="Auto-start a session at shell launch (captures startup-time perf)"
                      IsChecked="{Binding Settings.AutoStartPerfTrace, Mode=TwoWay}"
                      IsEnabled="{Binding Settings.EnablePerfTrace}"
                      Foreground="#FFE8E8E8" Margin="0,0,0,8"/>

            <CheckBox Content="Emit a frame event per render (verbose; larger files)"
                      IsChecked="{Binding Settings.VerboseFrameEvents, Mode=TwoWay}"
                      IsEnabled="{Binding Settings.EnablePerfTrace}"
                      Foreground="#FFE8E8E8" Margin="0,0,0,16"/>

            <TextBlock TextWrapping="Wrap" Foreground="#66FFFFFF"
                       FontSize="{DynamicResource AppFontSizeHint}" Margin="0,0,0,4"
                       Text="Sessions land in:"/>
            <TextBlock TextWrapping="Wrap" Foreground="#AAFFFFFF"
                       FontSize="{DynamicResource AppFontSizeHint}"
                       FontFamily="Consolas, Cascadia Mono"
                       Text="{Binding PerfDirectoryHint}" Margin="0,0,0,12"/>

            <TextBlock TextWrapping="Wrap" Foreground="#88FFFFFF"
                       FontSize="{DynamicResource AppFontSizeHint}" Margin="0,8,0,4"
                       Text="Bind a hotkey to 'Toggle perf-trace recording' under Hotkeys settings to start/stop a session on demand. The status bar shows a red REC dot while a session is active."/>

            <TextBlock Margin="0,24,0,0" TextWrapping="Wrap" Foreground="#66FFFFFF"
                       FontSize="{DynamicResource AppFontSizeHint}"
                       Text="Changes preview live. Settings persist on shutdown."/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
