<UserControl x:Class="Mithril.Shell.Views.AboutSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Background="#FF1A1A1A">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Mithril.Shared;component/Wpf/Resources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="640" HorizontalAlignment="Left">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Image Source="pack://application:,,,/Mithril;component/Resources/about.ico"
                       Width="28" Height="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="About" FontFamily="{DynamicResource AppHeaderFontFamily}"
                           FontSize="{DynamicResource AppFontSizeTitle}" Foreground="#FFD4A847"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- This build -->
            <TextBlock Text="This build" Foreground="#FFE8E8E8" FontWeight="SemiBold"
                       FontSize="{DynamicResource AppFontSizeLarge}" Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Version" Foreground="#88FFFFFF" Margin="0,2"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SemanticVersion}" Foreground="#FFE8E8E8" Margin="0,2"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Channel" Foreground="#88FFFFFF" Margin="0,2"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ChannelDisplay}" Foreground="#FFE8E8E8" Margin="0,2"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Commit" Foreground="#88FFFFFF" Margin="0,2"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CommitDisplay}" Foreground="#FFE8E8E8"
                           FontFamily="Consolas" Margin="0,2"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Built" Foreground="#88FFFFFF" Margin="0,2"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding BuildTimestampDisplay}"
                           Foreground="#FFE8E8E8" Margin="0,2"/>
            </Grid>

            <!-- Updates -->
            <TextBlock Text="Updates" Foreground="#FFE8E8E8" FontWeight="SemiBold"
                       FontSize="{DynamicResource AppFontSizeLarge}" Margin="0,8,0,6"/>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Status" Foreground="#88FFFFFF" Margin="0,2"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding StatusDisplay}"
                           Foreground="{Binding StatusBrush}" FontWeight="SemiBold" Margin="0,2"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Latest release" Foreground="#88FFFFFF" Margin="0,2"
                           Visibility="{Binding HasRemote, Converter={StaticResource BoolToVis}}"/>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,2"
                            Visibility="{Binding HasRemote, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="v" Foreground="#FFE8E8E8"/>
                    <TextBlock Text="{Binding RemoteDisplay}" Foreground="#FFE8E8E8"/>
                </StackPanel>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Last checked" Foreground="#88FFFFFF" Margin="0,2"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LastCheckedDisplay}"
                           Foreground="#FFE8E8E8" Margin="0,2"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Last error" Foreground="#88FFFFFF" Margin="0,2"
                           Visibility="{Binding HasLastError, Converter={StaticResource BoolToVis}}"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LastError}" TextWrapping="Wrap"
                           Foreground="#FFCC7766" Margin="0,2"
                           Visibility="{Binding HasLastError, Converter={StaticResource BoolToVis}}"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button Padding="12,6" Margin="0,0,8,0"
                        Background="#FF4A3820" Foreground="#FFF3E1B8"
                        Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVis}}"
                        Command="{Binding ApplyUpdateCommand}">
                    <StackPanel Orientation="Horizontal">
                        <icon:PackIconLucide Kind="Download" Width="14" Height="14"
                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Install update and restart" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Padding="12,6" Margin="0,0,8,0"
                        Command="{Binding CheckNowCommand}"
                        IsEnabled="{Binding NotChecking}">
                    <StackPanel Orientation="Horizontal">
                        <icon:PackIconLucide Kind="RefreshCw" Width="14" Height="14"
                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Check now" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Padding="12,6" Margin="0,0,8,0"
                        Command="{Binding OpenReleaseNotesCommand}">
                    <StackPanel Orientation="Horizontal">
                        <icon:PackIconLucide Kind="FileText" Width="14" Height="14"
                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Release notes" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Padding="12,6" Command="{Binding OpenRepoCommand}">
                    <StackPanel Orientation="Horizontal">
                        <icon:PackIconLucide Kind="Github" Width="14" Height="14"
                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Open repo on GitHub" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <TextBlock Text="Check interval" Foreground="#88FFFFFF" Margin="0,20,0,4" FontWeight="SemiBold"/>
            <TextBlock TextWrapping="Wrap" Foreground="#88FFFFFF" FontSize="{DynamicResource AppFontSizeHint}" Margin="0,0,0,6"
                       Text="How often Mithril polls GitHub Releases for a newer build while running. Minimum 0.25 h (15 min)."/>
            <DockPanel Width="420" HorizontalAlignment="Left" Margin="0,0,0,8">
                <TextBlock DockPanel.Dock="Right" Width="72" TextAlignment="Right"
                           Text="{Binding Settings.UpdateCheckIntervalHours, StringFormat={}{0:F2} h}"
                           Foreground="#FFE8E8E8" VerticalAlignment="Center" Margin="8,0,0,0"/>
                <Slider Minimum="0.25" Maximum="24"
                        Value="{Binding Settings.UpdateCheckIntervalHours, Mode=TwoWay}"
                        TickFrequency="1" IsSnapToTickEnabled="False"
                        SmallChange="0.25" LargeChange="1"
                        VerticalAlignment="Center"/>
            </DockPanel>

            <TextBlock Margin="0,16,0,0" TextWrapping="Wrap" Foreground="#66FFFFFF"
                       FontSize="{DynamicResource AppFontSizeHint}"
                       Text="Mithril polls GitHub Releases for a newer build in this channel. When one is available, click 'Install update and restart' to download and apply it. Development builds (run from source) skip the check entirely."/>

            <TextBlock Text="Deep linking" Foreground="#88FFFFFF" Margin="0,28,0,4" FontWeight="SemiBold"/>
            <TextBlock TextWrapping="Wrap" Foreground="#88FFFFFF" FontSize="{DynamicResource AppFontSizeHint}" Margin="0,0,0,6"
                       Text="Register a mithril:// URL handler so other apps can open Mithril directly at a specific item. Example: mithril://item/CraftedLeatherBoots5. Stored in your user registry (HKCU); no admin rights required."/>
            <TextBlock Text="{Binding LinkSchemeStatus}" Foreground="#CCFFFFFF"
                       FontSize="{DynamicResource AppFontSizeHint}" Margin="0,0,0,6"/>
            <Button Padding="12,6" HorizontalAlignment="Left"
                    Content="{Binding LinkSchemeButtonText}"
                    Command="{Binding ToggleLinkSchemeCommand}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
