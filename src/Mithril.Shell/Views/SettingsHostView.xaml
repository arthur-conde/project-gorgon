<UserControl x:Class="Mithril.Shell.Views.SettingsHostView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Background="#FF1A1A1A">
    <UserControl.Resources>
        <ResourceDictionary Source="pack://application:,,,/Mithril.Shared;component/Wpf/Converters.xaml"/>
    </UserControl.Resources>
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="16,12,16,12">
            <Image Source="pack://application:,,,/Mithril;component/Resources/settings.ico"
                   Width="28" Height="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock Text="Settings" FontFamily="{DynamicResource AppHeaderFontFamily}" FontSize="{DynamicResource AppFontSizeHero}" FontWeight="SemiBold"
                       Foreground="#FFD4A847" VerticalAlignment="Center"/>
        </StackPanel>

        <Border DockPanel.Dock="Left" Width="200" Background="#FF202020"
                BorderThickness="0,0,1,0" BorderBrush="#22FFFFFF">
            <ListBox ItemsSource="{Binding Sections}"
                     SelectedItem="{Binding SelectedSection, Mode=TwoWay}"
                     Background="Transparent" BorderThickness="0" Padding="4">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="4">
                            <Grid Width="20" Height="20" Margin="0,0,8,0">
                                <icon:PackIconLucide Kind="{Binding Icon}" Width="15" Height="15"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="{Binding HasImage, Converter={StaticResource InverseBoolToVis}}"/>
                                <Image Source="{Binding ImageSource}" Width="20" Height="20"
                                       Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                            <TextBlock Text="{Binding Title}" VerticalAlignment="Center" Foreground="#FFE8E8E8"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <ContentPresenter Content="{Binding ActiveContent}"/>
    </DockPanel>
</UserControl>
