<UserControl x:Class="Mithril.Shell.Views.DiagnosticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Background="#FF1A1A1A">
    <DockPanel Margin="12">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <Image Source="pack://application:,,,/Mithril;component/Resources/diagnostics.ico"
                       Width="28" Height="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Diagnostics" FontFamily="{DynamicResource AppHeaderFontFamily}" FontSize="{DynamicResource AppFontSizeHero}" FontWeight="SemiBold"
                           Foreground="#FFD4A847" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                <CheckBox Content="Trace" IsChecked="{Binding ShowTrace}" Foreground="#AAFFFFFF" Margin="6,0"/>
                <CheckBox Content="Info"  IsChecked="{Binding ShowInfo}"  Foreground="#AAFFFFFF" Margin="6,0"/>
                <CheckBox Content="Warn"  IsChecked="{Binding ShowWarn}"  Foreground="#AAFFFFFF" Margin="6,0"/>
                <CheckBox Content="Error" IsChecked="{Binding ShowError}" Foreground="#AAFFFFFF" Margin="6,0"/>
                <ToggleButton IsChecked="{Binding AutoScroll}" Padding="8,4" Margin="12,0,4,0"
                              ToolTip="Scroll to newest entry as they arrive">
                    <StackPanel Orientation="Horizontal">
                        <icon:PackIconLucide Kind="ArrowDownUp" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="Follow" VerticalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton IsChecked="{Binding Paused}" Padding="8,4" Margin="0,0,4,0">
                    <StackPanel Orientation="Horizontal">
                        <icon:PackIconLucide Kind="Pause" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="Pause" VerticalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
                <Button Padding="8,4" Margin="0,0,4,0" Command="{Binding ClearCommand}">
                    <StackPanel Orientation="Horizontal">
                        <icon:PackIconLucide Kind="X" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="Clear" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Padding="8,4" Command="{Binding CopyAllCommand}">
                    <StackPanel Orientation="Horizontal">
                        <icon:PackIconLucide Kind="ClipboardCopy" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="Copy" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </DockPanel>

        <TextBox DockPanel.Dock="Top" Margin="0,0,0,8" Padding="6,4"
                 Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                 Background="#FF252525" Foreground="#FFE8E8E8" BorderBrush="#33FFFFFF"/>

        <Border DockPanel.Dock="Top" Margin="0,0,0,8" Padding="6" CornerRadius="3"
                Background="#FF202020" BorderBrush="#22FFFFFF" BorderThickness="1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                    <Button Content="All"  Padding="8,2" Margin="0,0,4,0" Command="{Binding CategoriesAllCommand}"/>
                    <Button Content="None" Padding="8,2" Command="{Binding CategoriesNoneCommand}"/>
                </StackPanel>
                <ItemsControl ItemsSource="{Binding Categories}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="2" Padding="6,2" CornerRadius="2"
                                    Background="#FF252525" BorderBrush="#33FFFFFF" BorderThickness="1"
                                    MouseRightButtonUp="CategoryChip_RightClick">
                                <CheckBox Content="{Binding Name}" IsChecked="{Binding IsEnabled}"
                                          Foreground="#FFE8E8E8" FontFamily="{DynamicResource AppMonoFontFamily}" FontSize="{DynamicResource AppFontSizeHint}"
                                          ToolTip="Right-click to isolate only this category"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <ListBox x:Name="EntriesList" ItemsSource="{Binding View}" Background="#FF101010" Foreground="#FFE8E8E8"
                 BorderBrush="#33FFFFFF" FontFamily="{DynamicResource AppMonoFontFamily}" FontSize="{DynamicResource AppFontSize}"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 VirtualizingStackPanel.IsVirtualizing="True"
                 VirtualizingStackPanel.VirtualizationMode="Recycling">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Timestamp, StringFormat=HH:mm:ss.fff}" Foreground="#66FFFFFF" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Level}" Width="48" Margin="0,0,8,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#AAFFFFFF"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Level}" Value="Warn">
                                            <Setter Property="Foreground" Value="#FFE0A030"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Level}" Value="Error">
                                            <Setter Property="Foreground" Value="#FFD04040"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Level}" Value="Info">
                                            <Setter Property="Foreground" Value="#FFD4A847"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding Category}" Foreground="#FF88B0E0" Width="140" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Message}" TextWrapping="NoWrap"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
