<UserControl x:Class="Mithril.Shell.Views.ReferenceDataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:wpf="clr-namespace:Mithril.Shared.Wpf;assembly=Mithril.Shared"
             Background="#FF1A1A1A">
    <UserControl.Resources>
        <wpf:InverseBoolConverter x:Key="InverseBool"/>
        <wpf:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyVisibility"/>
    </UserControl.Resources>
    <StackPanel Margin="24,16" MaxWidth="720" HorizontalAlignment="Left">
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <Image Source="pack://application:,,,/Mithril;component/Resources/reference-data.ico"
                   Width="28" Height="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock Text="Reference Data"
                       FontFamily="{DynamicResource AppHeaderFontFamily}" FontSize="{DynamicResource AppFontSizeHero}" FontWeight="SemiBold"
                       Foreground="#FFD4A847" VerticalAlignment="Center"/>
        </StackPanel>
        <TextBlock TextWrapping="Wrap" Foreground="#88FFFFFF" FontSize="{DynamicResource AppFontSizeHint}" Margin="0,0,0,16"
                   Text="Game data published by the developer at cdn.projectgorgon.com. Refreshed in the background on app start. Use Refresh to pull the latest version on demand."/>

        <Button Content="Refresh all from CDN"
                Command="{Binding RefreshAllCommand}"
                IsEnabled="{Binding IsRefreshing, Converter={StaticResource InverseBool}}"
                Padding="10,4" HorizontalAlignment="Left" Margin="0,0,0,16"/>

        <ItemsControl ItemsSource="{Binding Files}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="#FF252525" Padding="14" Margin="0,0,0,10" CornerRadius="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Key}" FontWeight="Bold" Foreground="#FFE8E8E8" FontSize="{DynamicResource AppFontSizeLarge}"/>
                            <Button Grid.Row="0" Grid.Column="1" Content="Refresh"
                                    Command="{Binding RefreshFromCdnCommand}"
                                    IsEnabled="{Binding IsRefreshing, Converter={StaticResource InverseBool}}"
                                    Padding="10,3"/>

                            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Foreground="#88FFFFFF" Text="Source: "/>
                                <TextBlock Foreground="#FFE8E8E8" Text="{Binding Source}" Margin="0,0,16,0"/>
                                <TextBlock Foreground="#88FFFFFF" Text="Version: "/>
                                <TextBlock Foreground="#FFE8E8E8" Text="{Binding CdnVersion}" Margin="0,0,16,0"/>
                                <TextBlock Foreground="#88FFFFFF" Text="Entries: "/>
                                <TextBlock Foreground="#FFE8E8E8" Text="{Binding EntryCount}" Margin="0,0,16,0"/>
                                <TextBlock Foreground="#88FFFFFF" Text="Fetched: "/>
                                <TextBlock Foreground="#FFE8E8E8" Text="{Binding FetchedAt}"/>
                            </StackPanel>

                            <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                       Text="{Binding LastError}"
                                       Foreground="#FFFF6B6B" FontSize="{DynamicResource AppFontSizeHint}" Margin="0,8,0,0"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding LastError, Converter={StaticResource NullOrEmptyVisibility}}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
