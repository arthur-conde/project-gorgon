<UserControl x:Class="Mithril.Shell.Views.GameConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Background="#FF1A1A1A">
    <StackPanel Margin="24,16" MaxWidth="640" HorizontalAlignment="Left">
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <Image Source="pack://application:,,,/Mithril;component/Resources/game-folder.ico"
                   Width="28" Height="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock Text="Game Configuration"
                       FontFamily="{DynamicResource AppHeaderFontFamily}" FontSize="{DynamicResource AppFontSizeHero}" FontWeight="SemiBold"
                       Foreground="#FFD4A847" VerticalAlignment="Center"/>
        </StackPanel>

        <TextBlock Text="Project Gorgon root folder" Foreground="#88FFFFFF" Margin="0,0,0,4"/>
        <DockPanel LastChildFill="True">
            <Button DockPanel.Dock="Right" Content="Browse…" Padding="10,4" Margin="6,0,0,0" Command="{Binding BrowseCommand}"/>
            <Button DockPanel.Dock="Right" Content="Auto-detect" Padding="10,4" Margin="6,0,0,0" Command="{Binding AutoDetectCommand}"/>
            <TextBox Text="{Binding GameRoot, UpdateSourceTrigger=PropertyChanged}" Padding="6,4"/>
        </DockPanel>

        <TextBlock Text="Resolved Player.log" Foreground="#88FFFFFF" Margin="0,16,0,4"/>
        <TextBlock Text="{Binding PlayerLogPath}" FontFamily="{DynamicResource AppMonoFontFamily}" Foreground="#FFE8E8E8"/>

        <TextBlock Text="Poll interval (seconds)" Foreground="#88FFFFFF" Margin="0,16,0,4"/>
        <TextBox Text="{Binding PollSeconds, UpdateSourceTrigger=PropertyChanged}" Padding="6,4" Width="100" HorizontalAlignment="Left"/>

        <!-- #919: relocated here from the Legolas settings tab so the shared
             map-calibration capture engine can consume the value. -->
        <TextBlock Text="Game process name (case-insensitive substring match — covers ProjectGorgon, ProjectGorgon64, Project Gorgon, etc.)"
                   Foreground="#88FFFFFF" TextWrapping="Wrap" Margin="0,16,0,4"/>
        <StackPanel Orientation="Horizontal">
            <TextBox Width="240" VerticalAlignment="Center" Padding="6,4"
                     Text="{Binding GameProcessName, UpdateSourceTrigger=LostFocus}"/>
            <Button Content="Detect from foreground (3s)" Margin="8,0,0,0" Padding="8,4"
                    Command="{Binding DetectGameProcessCommand}"
                    ToolTip="Click, then alt-tab to the game window — its process name is captured after a 3-second countdown."/>
        </StackPanel>
        <TextBlock Text="{Binding DetectGameProcessStatus}" Foreground="#88FFFFFF" Margin="0,4,0,0"/>

        <TextBlock Text="Calibration good-residual threshold (px)" Foreground="#88FFFFFF" Margin="0,16,0,4"/>
        <TextBox Text="{Binding CalibrationGoodResidualPx, StringFormat=0.#, UpdateSourceTrigger=LostFocus}"
                 Padding="6,4" Width="100" HorizontalAlignment="Left"
                 ToolTip="RMS pixel residual at or below which a map calibration is considered good. Lower is stricter; 12 is the default."/>

        <TextBlock Margin="0,24,0,0" TextWrapping="Wrap" Foreground="#88FFFFFF" FontSize="{DynamicResource AppFontSizeHint}"
                   Text="Modules subscribe to this folder. Changes apply immediately — the log tail restarts when the path changes."/>
    </StackPanel>
</UserControl>
