<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationHighDpiMode>PerMonitorV2</ApplicationHighDpiMode>
    <ApplicationIcon>Resources\mithril.ico</ApplicationIcon>
    <RootNamespace>Mithril.Shell</RootNamespace>
    <AssemblyName>Mithril</AssemblyName>
    <EnableDefaultApplicationEntryPoint>false</EnableDefaultApplicationEntryPoint>
    <StartupObject>Mithril.Shell.Program</StartupObject>
    <!-- #919: GameConfigViewModel's "Detect from foreground" uses [LibraryImport]
         P/Invokes (GetForegroundWindow / GetWindowThreadProcessId); the
         source-generated marshalling stubs require unsafe code (SYSLIB1062 /
         CS0227). Matches Legolas.Module, which set this for the same interop. -->
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>

    <!-- Reflection-based module loader requires DLLs on disk under modules/. -->
    <PublishSingleFile>false</PublishSingleFile>
    <!-- Modules use Activator.CreateInstance; trimming would remove their types. -->
    <PublishTrimmed>false</PublishTrimmed>
    <PublishReadyToRun>true</PublishReadyToRun>

    <!-- Set by CI per SKU (-p:MithrilUpdateChannel=fxdep|selfcontained). 'dev' is the
         local-dev sentinel: VelopackUpdateChecker short-circuits so F5 builds never poll. -->
    <MithrilUpdateChannel Condition="'$(MithrilUpdateChannel)' == ''">dev</MithrilUpdateChannel>

    <!-- Opts this project into the XAML StaticResource lint (see Directory.Build.targets).
         Only the Shell needs it — modules are validated as a side-effect since the linter
         scans the whole repo. -->
    <RunsXamlResourceLint>true</RunsXamlResourceLint>
  </PropertyGroup>
  <ItemGroup>
    <AssemblyAttribute Include="System.Reflection.AssemblyMetadataAttribute">
      <_Parameter1>MithrilUpdateChannel</_Parameter1>
      <_Parameter2>$(MithrilUpdateChannel)</_Parameter2>
    </AssemblyAttribute>
    <InternalsVisibleTo Include="Mithril.Shell.Tests" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" />
    <PackageReference Include="Microsoft.Extensions.Hosting" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="System.Reactive" />
    <PackageReference Include="Hardcodet.NotifyIcon.Wpf" />
    <PackageReference Include="MahApps.Metro.IconPacks.Lucide" />
    <PackageReference Include="Velopack" />
  </ItemGroup>
  <ItemGroup>
    <Resource Include="Resources\mithril.ico" />
    <Resource Include="Resources\game-folder.ico" />
    <Resource Include="Resources\reference-data.ico" />
    <Resource Include="Resources\icons.ico" />
    <Resource Include="Resources\diagnostics.ico" />
    <Resource Include="Resources\hotkeys.ico" />
    <Resource Include="Resources\settings.ico" />
    <Resource Include="Resources\appearance.ico" />
    <Resource Include="Resources\about.ico" />
    <Resource Include="Resources\perf-trace.ico" />
    <Resource Include="Resources\attention-overlay.ico" />
    <Resource Include="Resources\mithril-attention.ico" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Arda\Arda.Contracts\Arda.Contracts.csproj" />
    <ProjectReference Include="..\Arda\Arda.Composition\Arda.Composition.csproj" />
    <ProjectReference Include="..\Arda\Arda.Wpf\Arda.Wpf.csproj" />
    <ProjectReference Include="..\Arda\Arda.World.Chat\Arda.World.Chat.csproj" />
    <ProjectReference Include="..\Arda\Arda.World.Player\Arda.World.Player.csproj" />
    <ProjectReference Include="..\Mithril.Shared\Mithril.Shared.csproj" />
    <!-- Telemetry assembly: needed so ShellComposition can hand the trace-context
         Serilog enricher to AddMithrilLogging. Mithril.Shared can't reference
         Mithril.Shared.Telemetry directly (would be a dep cycle). -->
    <ProjectReference Include="..\Mithril.Shared.Telemetry\Mithril.Shared.Telemetry.csproj" />
    <!-- Foundation-layer assembly for character export reports (storage/vault
         items, character snapshots). Mithril.Shared transitively pulls this,
         but listing it here makes the dependency explicit per the discipline
         note in CLAUDE.md / memory: shell must ProjectReference new shared
         libs so their DLLs land in the app base dir for the reflection
         module loader to resolve. -->
    <ProjectReference Include="..\Mithril.GameReports\Mithril.GameReports.csproj" />
    <ProjectReference Include="..\Mithril.Shared.Wpf\Mithril.Shared.Wpf.csproj" />
    <!-- Shared leveling/planning libs. The shell must reference these so their
         DLLs land in the app base dir for the reflection module loader to resolve:
         modules not <ProjectReference>'d here (Celebrimbor) are copied as
         *.Module.dll only, NOT their shared-lib deps. Mithril.Leveling previously
         arrived transitively via Elrond's ref — fragile; make it explicit. -->
    <ProjectReference Include="..\Mithril.Leveling\Mithril.Leveling.csproj" />
    <ProjectReference Include="..\Mithril.MapCalibration\Mithril.MapCalibration.csproj" />
    <!-- Mithril.MapCalibration.Capture (#914 PR-2a): windows-only capture infra
         (CsWin32 BitBlt). Shell must reference it so the DLL lands in the app
         base dir even though no DI wiring consumes it yet (Phase 3 wires the
         orchestrator + hotkeys). Memory pointer: shell_must_projectref_shared_libs. -->
    <ProjectReference Include="..\Mithril.MapCalibration.Capture\Mithril.MapCalibration.Capture.csproj" />
    <!-- Mithril.Overlay (#835): scaffold-only. Shell must reference so the
         DLL lands in the app base dir for the reflection module loader to
         resolve when consumer modules call IWorldOverlayMarkers / IOverlayWindow
         post-migration. Memory pointer: shell_must_projectref_shared_libs. -->
    <ProjectReference Include="..\Mithril.Overlay\Mithril.Overlay.csproj" />
    <ProjectReference Include="..\Mithril.Planning\Mithril.Planning.csproj" />
    <ProjectReference Include="..\Samwise.Module\Samwise.Module.csproj" />
    <ProjectReference Include="..\Legolas.Module\Legolas.Module.csproj" />
    <ProjectReference Include="..\Gandalf.Module\Gandalf.Module.csproj" />
    <ProjectReference Include="..\Elrond.Module\Elrond.Module.csproj" />
    <ProjectReference Include="..\Bilbo.Module\Bilbo.Module.csproj" />
    <ProjectReference Include="..\Pippin.Module\Pippin.Module.csproj" />
  </ItemGroup>

  <!--
    Stage every sibling *.Module/bin/$(Configuration)/$(TargetFramework)/*.Module.dll into
    $(PublishDir)modules/ so the reflection loader finds them. This globs against the build
    output, so a solution-wide `dotnet build` must precede `dotnet publish src/Mithril.Shell`
    for the modules that are not <ProjectReference>'d here (Arwen, Saruman, Smaug, Celebrimbor)
    to land in the publish folder.
  -->
  <Target Name="StageMithrilModulesForPublish" AfterTargets="Publish">
    <ItemGroup>
      <_MithrilModuleDlls Include="$(MSBuildThisFileDirectory)..\*.Module\bin\$(Configuration)\$(TargetFramework)\*.Module.dll" />
    </ItemGroup>
    <MakeDir Directories="$(PublishDir)modules" />
    <Copy SourceFiles="@(_MithrilModuleDlls)"
          DestinationFolder="$(PublishDir)modules"
          SkipUnchangedFiles="true" />
  </Target>

  <!--
    #951: stage the out-of-process asset-extractor sidecar (mithril-asset-extract.exe)
    next to Mithril.exe on local/dev builds. The sidecar lives in
    tools/Mithril.AssetExtractor (in Mithril.MapCalibration.Tools.slnx, NOT Mithril.slnx),
    so a normal Shell build never produces it — yet ProcessAssetExtractor resolves it via
    Path.Combine(AppContext.BaseDirectory, "mithril-asset-extract.exe") and fail-softs
    ExitMissingExe when it's absent, blocking local auto-calibration testing (#938).

    We publish it OUT-OF-BAND (Exec dotnet publish) and copy the single produced exe into
    $(OutDir). This is deliberately NOT a <ProjectReference>: a reference from src/** to the
    sidecar / Tools.Common would drag AssetsTools.NET + System.Drawing into the shipped graph
    and trip ShippedGraphDecoderFreeTests (#921). Copy, never reference. Published
    framework-dependent single-file (fast inner loop, one self-contained artifact, no loose
    decoder DLLs polluting the shell output dir); release.yml keeps its own self-contained
    single-file publish for shipped packs.

    Gated off in CI (GITHUB_ACTIONS) so the test pipeline and release.yml — which has its own
    explicit sidecar publish steps — don't double-publish. Incremental via Inputs/Outputs:
    skipped entirely when the staged exe is newer than every sidecar source. Fail-soft: the
    Exec is ContinueOnError so a contributor without the tools just gets no exe (safe-degrade),
    never a broken Shell build.
  -->
  <!-- Gate property: distinct name from the target below by convention.
       Override with -p:StageAssetExtractorSidecarEnabled=false. -->
  <PropertyGroup>
    <StageAssetExtractorSidecarEnabled Condition="'$(StageAssetExtractorSidecarEnabled)' == '' and '$(GITHUB_ACTIONS)' != 'true'">true</StageAssetExtractorSidecarEnabled>
    <StageAssetExtractorSidecarEnabled Condition="'$(StageAssetExtractorSidecarEnabled)' == ''">false</StageAssetExtractorSidecarEnabled>
  </PropertyGroup>

  <ItemGroup Condition="'$(StageAssetExtractorSidecarEnabled)' == 'true'">
    <_AssetExtractorSrc Include="$(MSBuildThisFileDirectory)..\..\tools\Mithril.AssetExtractor\**\*.cs;$(MSBuildThisFileDirectory)..\..\tools\Mithril.AssetExtractor\*.csproj"
                        Exclude="$(MSBuildThisFileDirectory)..\..\tools\Mithril.AssetExtractor\**\bin\**;$(MSBuildThisFileDirectory)..\..\tools\Mithril.AssetExtractor\**\obj\**" />
    <_AssetExtractorSrc Include="$(MSBuildThisFileDirectory)..\..\tools\Mithril.MapCalibration.Tools.Common\**\*.cs;$(MSBuildThisFileDirectory)..\..\tools\Mithril.MapCalibration.Tools.Common\*.csproj"
                        Exclude="$(MSBuildThisFileDirectory)..\..\tools\Mithril.MapCalibration.Tools.Common\**\bin\**;$(MSBuildThisFileDirectory)..\..\tools\Mithril.MapCalibration.Tools.Common\**\obj\**" />
    <_AssetExtractorSrc Include="$(MSBuildThisFileDirectory)..\Mithril.MapCalibration\**\*.cs;$(MSBuildThisFileDirectory)..\Mithril.MapCalibration\*.csproj"
                        Exclude="$(MSBuildThisFileDirectory)..\Mithril.MapCalibration\**\bin\**;$(MSBuildThisFileDirectory)..\Mithril.MapCalibration\**\obj\**" />
  </ItemGroup>

  <Target Name="StageAssetExtractorSidecar"
          AfterTargets="Build"
          Condition="'$(StageAssetExtractorSidecarEnabled)' == 'true' and '$(DesignTimeBuild)' != 'true'"
          Inputs="@(_AssetExtractorSrc)"
          Outputs="$(OutDir)mithril-asset-extract.exe">
    <Message Importance="high" Text="Staging asset-extractor sidecar (fxdep single-file) → $(OutDir)" />
    <Exec ContinueOnError="true"
          Command="dotnet publish &quot;$(MSBuildThisFileDirectory)..\..\tools\Mithril.AssetExtractor\Mithril.AssetExtractor.csproj&quot; -c $(Configuration) -r win-x64 --self-contained false -p:PublishSingleFile=true -o &quot;$(IntermediateOutputPath)assetextractor&quot;" />
    <ItemGroup>
      <_StagedSidecarExe Include="$(IntermediateOutputPath)assetextractor\mithril-asset-extract.exe" />
    </ItemGroup>
    <Copy Condition="'@(_StagedSidecarExe)' != ''"
          SourceFiles="@(_StagedSidecarExe)"
          DestinationFolder="$(OutDir)"
          SkipUnchangedFiles="true" />
    <Warning Condition="!Exists('$(IntermediateOutputPath)assetextractor\mithril-asset-extract.exe')"
             Text="asset-extractor sidecar was not produced; auto-calibration will safe-degrade locally (ExitMissingExe). Build tools/Mithril.MapCalibration.Tools.slnx if you need it." />
  </Target>
</Project>
