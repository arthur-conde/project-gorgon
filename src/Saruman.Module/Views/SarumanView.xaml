<UserControl x:Class="Saruman.Views.SarumanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Saruman.ViewModels"
             xmlns:icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:SarumanViewModel}"
             Background="#FF1A1A1A">
    <UserControl.Resources>
        <Style x:Key="CodeCellText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSpent}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}"/>
                    <Setter Property="TextDecorations" Value="Strikethrough"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <DockPanel Margin="16">
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Image Source="pack://application:,,,/Saruman.Module;component/Resources/saruman.ico"
                       Width="28" Height="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Saruman · Words of Power"
                           FontFamily="Cambria" FontSize="22" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
            </StackPanel>
            <WrapPanel>
                <TextBlock Margin="0,0,20,0">
                    <Run Text="{Binding TrackedCount, Mode=OneWay}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                    <Run Text=" tracked" Foreground="{StaticResource TextTertiaryBrush}"/>
                </TextBlock>
                <TextBlock>
                    <Run Text="{Binding SpentCount, Mode=OneWay}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                    <Run Text=" spent" Foreground="{StaticResource TextTertiaryBrush}"/>
                </TextBlock>
            </WrapPanel>
        </StackPanel>

        <!-- Toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="Copy all tracked" Margin="0,0,8,0"
                    Command="{Binding CopyAllTrackedCommand}"
                    ToolTip="Copy every still-usable code (grouped by tier) to the clipboard"/>
            <CheckBox Content="Hide spent" IsChecked="{Binding HideSpent}"
                      VerticalAlignment="Center" Margin="8,0,0,0"/>
        </StackPanel>

        <!-- Content area: empty state and codebook overlay the same cell so the
             empty panel can center against the full remaining space. -->
        <Grid>
            <!-- Empty state -->
            <StackPanel Visibility="{Binding HasData, Converter={StaticResource InverseBoolToVis}}"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        MaxWidth="420">
                <icon:PackIconLucide Kind="BookOpen" Width="56" Height="56"
                                     Foreground="#66D4A847"
                                     HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="No Words of Power discovered yet"
                           FontFamily="Cambria" FontSize="18"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap" TextAlignment="Center"
                           Foreground="{StaticResource TextTertiaryBrush}" FontSize="12">
                    Craft a Word of Power recipe in-game; discoveries will appear here automatically.
                    Anyone speaking a tracked code in chat will mark it spent.
                </TextBlock>
            </StackPanel>

            <!-- Codebook grid -->
            <DataGrid ItemsSource="{Binding WordsView}"
                      Visibility="{Binding HasData, Converter={StaticResource BoolToVis}}"
                      CanUserSortColumns="False">
            <DataGrid.GroupStyle>
                <GroupStyle>
                    <GroupStyle.ContainerStyle>
                        <Style TargetType="GroupItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="GroupItem">
                                        <Expander IsExpanded="True"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Foreground="{StaticResource AccentBrush}">
                                            <Expander.Header>
                                                <DockPanel>
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Margin="8,0,0,0" VerticalAlignment="Center"
                                                               Foreground="{StaticResource TextTertiaryBrush}">
                                                        <Run Text="("/>
                                                        <Run Text="{Binding ItemCount, Mode=OneWay}"/>
                                                        <Run Text=")"/>
                                                    </TextBlock>
                                                </DockPanel>
                                            </Expander.Header>
                                            <ItemsPresenter/>
                                        </Expander>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GroupStyle.ContainerStyle>
                </GroupStyle>
            </DataGrid.GroupStyle>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                    <Setter Property="ContextMenu">
                        <Setter.Value>
                            <ContextMenu>
                                <MenuItem Header="Copy code"
                                          Command="{Binding PlacementTarget.DataContext.DataContext.CopyCodeCommand, RelativeSource={RelativeSource Self}}"
                                          CommandParameter="{Binding PlacementTarget.DataContext.Code, RelativeSource={RelativeSource Self}}"/>
                                <MenuItem Header="Mark as spent"
                                          Command="{Binding PlacementTarget.DataContext.DataContext.MarkSpentCommand, RelativeSource={RelativeSource Self}}"
                                          CommandParameter="{Binding PlacementTarget.DataContext.Code, RelativeSource={RelativeSource Self}}"/>
                                <MenuItem Header="Restore as known"
                                          Command="{Binding PlacementTarget.DataContext.DataContext.MarkKnownCommand, RelativeSource={RelativeSource Self}}"
                                          CommandParameter="{Binding PlacementTarget.DataContext.Code, RelativeSource={RelativeSource Self}}"/>
                                <Separator/>
                                <MenuItem Header="Remove"
                                          Command="{Binding PlacementTarget.DataContext.DataContext.RemoveWordCommand, RelativeSource={RelativeSource Self}}"
                                          CommandParameter="{Binding PlacementTarget.DataContext.Code, RelativeSource={RelativeSource Self}}"/>
                            </ContextMenu>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSpent}" Value="True">
                            <Setter Property="Opacity" Value="0.55"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Code" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Code}" Style="{StaticResource CodeCellText}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Effect" Binding="{Binding EffectName}" Width="180"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Discovered" Binding="{Binding FirstDiscoveredAt, StringFormat=g}" Width="130"/>
                <DataGridTemplateColumn Header="" Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Copy"
                                    Padding="8,2" MinHeight="20"
                                    IsEnabled="{Binding IsKnown}"
                                    Command="{Binding DataContext.CopyCodeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding Code}"
                                    ToolTip="Copy this code to the clipboard"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </DockPanel>
</UserControl>
