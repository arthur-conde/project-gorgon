<UserControl x:Class="Smaug.Views.SellPlannerTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Smaug.ViewModels"
             xmlns:wpf="clr-namespace:Mithril.Shared.Wpf;assembly=Mithril.Shared"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:SellPlannerViewModel}"
             Background="#FF1A1A1A">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Mithril.Shared;component/Wpf/Resources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="TextCol" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#FFE8E8E8"/>
                <Setter Property="Padding" Value="6,4"/>
            </Style>
            <Style x:Key="SubtleCol" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#88FFFFFF"/>
                <Setter Property="Padding" Value="6,4"/>
            </Style>
            <Style x:Key="NumCol" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#FFD4A847"/>
                <Setter Property="Padding" Value="6,4"/>
                <Setter Property="TextAlignment" Value="Right"/>
            </Style>
            <Style x:Key="CountCol" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#FF7AB880"/>
                <Setter Property="Padding" Value="6,4"/>
                <Setter Property="TextAlignment" Value="Right"/>
            </Style>
            <Style x:Key="VendorRowStyle" TargetType="DataGridRow">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsAccessible}" Value="False">
                        <Setter Property="Foreground" Value="#66FFFFFF"/>
                        <Setter Property="Opacity" Value="0.55"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel Margin="12">
        <!-- Header -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <TextBlock Text="Sell Planner" FontSize="{DynamicResource AppFontSizeHeader}"
                       FontWeight="SemiBold" Foreground="#FFE8E8E8" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding StatusMessage}" Foreground="#88FFFFFF"
                       FontSize="{DynamicResource AppFontSize}"
                       VerticalAlignment="Center" Margin="16,0,0,0"/>
        </DockPanel>

        <!-- Two-column master/detail -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: items from the active character's storage -->
            <DockPanel Grid.Column="0">
                <TextBox DockPanel.Dock="Top"
                         Text="{Binding ItemFilter, UpdateSourceTrigger=PropertyChanged}"
                         Background="#FF1F1F1F" Foreground="#FFE8E8E8"
                         BorderBrush="#33FFFFFF" BorderThickness="1"
                         Padding="6,4" Margin="0,0,0,6"
                         FontSize="{DynamicResource AppFontSize}"/>
                <Border BorderBrush="#33FFFFFF" BorderThickness="1" Background="#FF1F1F1F">
                    <ListBox ItemsSource="{Binding ItemsView}"
                             SelectedItem="{Binding SelectedItem}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.IsVirtualizing="True">
                        <ListBox.Resources>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="10,6"/>
                                <Setter Property="Foreground" Value="#FFE8E8E8"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#3FD4A847"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#18FFFFFF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Resources>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <wpf:IconNameCell IconId="{Binding IconId}" DisplayName="{Binding DisplayName}"/>
                                        <TextBlock Foreground="#66FFFFFF"
                                                   FontSize="{DynamicResource AppFontSizeHint}"
                                                   Margin="34,0,0,0">
                                            <Run Text="x"/>
                                            <Run Text="{Binding StackCount, Mode=OneWay, StringFormat=N0}"/>
                                            <Run Text=" · "/>
                                            <Run Text="{Binding Location, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding UnitValue, StringFormat=N0}"
                                               Foreground="#88D4A847"
                                               FontSize="{DynamicResource AppFontSizeMedium}"
                                               VerticalAlignment="Center" Margin="6,0"/>
                                    <TextBlock Grid.Column="2" Text="c"
                                               Foreground="#66D4A847"
                                               FontSize="{DynamicResource AppFontSizeHint}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </DockPanel>

            <!-- Right: vendors, sorted by expected sell price -->
            <DockPanel Grid.Column="2">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding SelectedItem.DisplayName, FallbackValue='No item selected'}"
                                   FontSize="{DynamicResource AppFontSizeMedium}"
                                   FontWeight="SemiBold" Foreground="#FFD4A847"/>
                        <TextBlock Text="{Binding SelectedItem.UnitValue, StringFormat=' — base {0:N0}c', FallbackValue=''}"
                                   Foreground="#88FFFFFF"
                                   FontSize="{DynamicResource AppFontSizeMedium}" Margin="6,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Filter" Foreground="#88FFFFFF"
                               FontSize="{DynamicResource AppFontSizeHint}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <wpf:MithrilQueryBox Grid.Column="1"
                                        Grid="{Binding ElementName=VendorsGrid}"
                                        QueryText="{Binding ElementName=VendorsGrid, Path=QueryText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Watermark="type text, or grammar like Area CONTAINS 'Serbule'"/>
                </Grid>
                <TextBlock DockPanel.Dock="Top"
                           Text="{Binding ElementName=VendorsGrid, Path=QueryError}"
                           Foreground="#FFCC6666" FontSize="{DynamicResource AppFontSizeHint}" Margin="0,0,0,6"
                           Visibility="{Binding ElementName=VendorsGrid, Path=QueryError,
                               Converter={StaticResource NullOrEmptyToVis}}"/>

                <wpf:MithrilDataGrid x:Name="VendorsGrid" ItemsSource="{Binding Vendors}"
                                    Mode="ReadOnly" CanUserResizeRows="False"
                                    RowStyle="{StaticResource VendorRowStyle}">
                    <wpf:MithrilDataGrid.Columns>
                        <DataGridTextColumn Header="Vendor" Binding="{Binding NpcName}" Width="*"
                                            ElementStyle="{StaticResource TextCol}"/>
                        <DataGridTextColumn Header="Area" Binding="{Binding Area}" Width="160"
                                            ElementStyle="{StaticResource SubtleCol}"/>
                        <DataGridTextColumn Header="Expected" Binding="{Binding ExpectedPriceText}" Width="120"
                                            ElementStyle="{StaticResource NumCol}"/>
                        <DataGridTextColumn Header="Samples" Binding="{Binding SampleCount, StringFormat=N0}" Width="80"
                                            ElementStyle="{StaticResource CountCol}"/>
                        <DataGridTextColumn Header="Req." Binding="{Binding MinFavorTier}" Width="100"
                                            ElementStyle="{StaticResource SubtleCol}"/>
                        <DataGridTextColumn Header="You" Binding="{Binding PlayerFavorTier}" Width="100"
                                            ElementStyle="{StaticResource SubtleCol}"/>
                    </wpf:MithrilDataGrid.Columns>
                </wpf:MithrilDataGrid>
            </DockPanel>
        </Grid>
    </DockPanel>
</UserControl>
