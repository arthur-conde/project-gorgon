<UserControl x:Class="Smaug.Views.VendorCatalogTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Smaug.ViewModels"
             xmlns:wpf="clr-namespace:Mithril.Shared.Wpf;assembly=Mithril.Shared"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:VendorCatalogViewModel}"
             Background="#FF1A1A1A">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Mithril.Shared;component/Wpf/Resources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="TextCol" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#FFE8E8E8"/>
                <Setter Property="Padding" Value="6,4"/>
            </Style>
            <Style x:Key="SubtleCol" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#88FFFFFF"/>
                <Setter Property="Padding" Value="6,4"/>
            </Style>
            <Style x:Key="NumCol" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#FFD4A847"/>
                <Setter Property="Padding" Value="6,4"/>
                <Setter Property="TextAlignment" Value="Right"/>
            </Style>
            <Style x:Key="CatalogRowStyle" TargetType="DataGridRow">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsAcceptable}" Value="False">
                        <Setter Property="Foreground" Value="#66FFFFFF"/>
                        <Setter Property="Opacity" Value="0.55"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel Margin="12">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <TextBlock Text="Vendor Catalog" FontSize="{DynamicResource AppFontSizeHeader}"
                       FontWeight="SemiBold" Foreground="#FFE8E8E8" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding StatusMessage}" Foreground="#88FFFFFF"
                       FontSize="{DynamicResource AppFontSize}" VerticalAlignment="Center" Margin="16,0,0,0"/>
        </DockPanel>

        <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Filter" Foreground="#88FFFFFF"
                       FontSize="{DynamicResource AppFontSizeHint}"
                       VerticalAlignment="Center" Margin="0,0,6,0"/>
            <wpf:MithrilQueryBox Grid.Column="1"
                                Grid="{Binding ElementName=CatalogGrid}"
                                QueryText="{Binding ElementName=CatalogGrid, Path=QueryText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Watermark="type text, or grammar like Area = 'Serbule Hills'"/>
        </Grid>
        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding ElementName=CatalogGrid, Path=QueryError}"
                   Foreground="#FFCC6666" FontSize="{DynamicResource AppFontSizeHint}" Margin="0,0,0,6"
                   Visibility="{Binding ElementName=CatalogGrid, Path=QueryError,
                       Converter={StaticResource NullOrEmptyToVis}}"/>

        <wpf:MithrilDataGrid x:Name="CatalogGrid" ItemsSource="{Binding Rows}"
                            Mode="ReadOnly" CanUserResizeRows="False"
                            RowStyle="{StaticResource CatalogRowStyle}">
            <wpf:MithrilDataGrid.Columns>
                <DataGridTemplateColumn Header="Item" Width="220" SortMemberPath="ItemName">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <wpf:IconNameCell IconId="{Binding IconId}" DisplayName="{Binding ItemName}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Vendor" Binding="{Binding NpcName}" Width="170"
                                    ElementStyle="{StaticResource TextCol}"/>
                <DataGridTextColumn Header="Area" Binding="{Binding Area}" Width="150"
                                    ElementStyle="{StaticResource SubtleCol}"/>
                <DataGridTextColumn Header="Value" Binding="{Binding BaseValue, StringFormat=N0}" Width="80"
                                    ElementStyle="{StaticResource NumCol}"/>
                <DataGridTextColumn Header="Req. Favor" Binding="{Binding MinFavorTier}" Width="110"
                                    ElementStyle="{StaticResource SubtleCol}"/>
                <DataGridTextColumn Header="Accepts" Binding="{Binding Acceptance}" Width="130"
                                    ElementStyle="{StaticResource SubtleCol}"/>
            </wpf:MithrilDataGrid.Columns>
        </wpf:MithrilDataGrid>
    </DockPanel>
</UserControl>
