<UserControl x:Class="Smaug.Views.VendorShopTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Smaug.ViewModels"
             xmlns:wpf="clr-namespace:Gorgon.Shared.Wpf;assembly=Gorgon.Shared"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:VendorShopViewModel}"
             Background="#FF1A1A1A">

    <UserControl.Resources>
        <Style x:Key="TextCol" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFE8E8E8"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>
        <Style x:Key="SubtleCol" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#88FFFFFF"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>
        <Style x:Key="NumCol" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFD4A847"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="TextAlignment" Value="Right"/>
        </Style>
        <Style x:Key="CountCol" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF7AB880"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="TextAlignment" Value="Right"/>
        </Style>
    </UserControl.Resources>

    <DockPanel Margin="12">
        <!-- Header -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <TextBlock Text="Vendor Shop" FontSize="{DynamicResource AppFontSizeHeader}"
                       FontWeight="SemiBold" Foreground="#FFE8E8E8" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding StatusMessage}" Foreground="#88FFFFFF"
                       FontSize="{DynamicResource AppFontSize}"
                       VerticalAlignment="Center" Margin="16,0,0,0"/>
        </DockPanel>

        <!-- Two-column master/detail -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: vendor list grouped by Area -->
            <Border Grid.Column="0" BorderBrush="#33FFFFFF" BorderThickness="1" Background="#FF1F1F1F">
                <ListBox ItemsSource="{Binding VendorsView}"
                         SelectedItem="{Binding SelectedVendor}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True">
                    <ListBox.Resources>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="10,6"/>
                            <Setter Property="Foreground" Value="#FFE8E8E8"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#3FD4A847"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#18FFFFFF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Resources>
                    <ListBox.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <Border Background="#FF2A2A2A" Padding="10,4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" Foreground="#FFD4A847"
                                                       FontWeight="SemiBold"
                                                       FontSize="{DynamicResource AppFontSizeMedium}"/>
                                            <TextBlock Text="{Binding ItemCount, StringFormat=' · {0} vendors'}"
                                                       Foreground="#66FFFFFF"
                                                       FontSize="{DynamicResource AppFontSizeHint}"
                                                       VerticalAlignment="Center" Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListBox.GroupStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding NpcName}"
                                           Foreground="#FFE8E8E8"
                                           FontSize="{DynamicResource AppFontSizeMedium}"/>
                                <TextBlock Grid.Column="1" Text="{Binding MinFavorTier}"
                                           Foreground="#88FFFFFF"
                                           FontSize="{DynamicResource AppFontSizeHint}"
                                           Margin="6,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding ItemCount}"
                                           Foreground="#FF7AB880"
                                           FontSize="{DynamicResource AppFontSizeHint}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Right: items sold by selected vendor -->
            <DockPanel Grid.Column="2">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding SelectedVendor.NpcName, FallbackValue='No vendor selected'}"
                                   FontSize="{DynamicResource AppFontSizeMedium}"
                                   FontWeight="SemiBold" Foreground="#FFD4A847"/>
                        <TextBlock Text="{Binding SelectedVendor.Area, StringFormat=' — {0}', FallbackValue=''}"
                                   Foreground="#88FFFFFF"
                                   FontSize="{DynamicResource AppFontSizeMedium}" Margin="6,0,0,0"/>
                        <TextBlock Text="{Binding SelectedVendor.MinFavorTier, StringFormat=' (req. {0})', FallbackValue=''}"
                                   Foreground="#66FFFFFF"
                                   FontSize="{DynamicResource AppFontSizeHint}"
                                   VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Filter" Foreground="#88FFFFFF"
                               FontSize="{DynamicResource AppFontSizeHint}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <wpf:GorgonQueryBox Grid.Column="1"
                                        Grid="{Binding ElementName=ItemsGrid}"
                                        QueryText="{Binding ElementName=ItemsGrid, Path=QueryText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Watermark="type text, or grammar like ItemName CONTAINS 'Ring'"/>
                </Grid>
                <TextBlock DockPanel.Dock="Top"
                           Text="{Binding ElementName=ItemsGrid, Path=QueryError}"
                           Foreground="#FFCC6666" FontSize="{DynamicResource AppFontSizeHint}" Margin="0,0,0,6"
                           Visibility="{Binding ElementName=ItemsGrid, Path=QueryError,
                               Converter={StaticResource NullOrEmptyToVis}}"/>

                <wpf:GorgonDataGrid x:Name="ItemsGrid" ItemsSource="{Binding SelectedVendorItems}"
                                    Mode="ReadOnly" CanUserResizeRows="False">
                    <wpf:GorgonDataGrid.Columns>
                        <DataGridTemplateColumn Header="Item" Width="*" SortMemberPath="ItemName">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <wpf:IconNameCell IconId="{Binding IconId}" DisplayName="{Binding ItemName}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Value" Binding="{Binding BaseValue, StringFormat=N0}" Width="100"
                                            ElementStyle="{StaticResource NumCol}"/>
                    </wpf:GorgonDataGrid.Columns>
                </wpf:GorgonDataGrid>
            </DockPanel>
        </Grid>
    </DockPanel>
</UserControl>
