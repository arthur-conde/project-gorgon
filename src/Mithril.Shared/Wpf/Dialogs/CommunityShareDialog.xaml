<UserControl x:Class="Mithril.Shared.Wpf.Dialogs.CommunityShareDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Mithril.Shared.Wpf.Dialogs"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:CommunityShareDialogViewModel}"
             MinWidth="520" MaxWidth="620">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Mithril.Shared;component/Wpf/Resources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <StackPanel>
        <TextBlock Text="Share your calibration data with the community. The aggregator merges it with other players' contributions and publishes the result for everyone to benefit from."
                   TextWrapping="Wrap" Foreground="#CCFFFFFF" FontSize="{DynamicResource AppFontSize}" Margin="0,0,0,10"/>

        <TextBlock Text="Optional note (shows up on the issue, not in the aggregated data):"
                   Foreground="#88FFFFFF" FontSize="{DynamicResource AppFontSizeHint}" Margin="0,0,0,4"/>
        <TextBox Text="{Binding ContributorNote, UpdateSourceTrigger=PropertyChanged}"
                 MaxLength="300" Margin="0,0,0,10"
                 Background="#FF2A2A2A" Foreground="#FFE8E8E8" BorderBrush="#FF444444" Padding="6,4"/>

        <TextBlock Text="Preview (sanitized — no raw observations, no character names):"
                   Foreground="#88FFFFFF" FontSize="{DynamicResource AppFontSizeHint}" Margin="0,0,0,4"/>
        <TextBox Text="{Binding JsonPreview, Mode=OneWay}" IsReadOnly="True"
                 Height="220" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas,Cascadia Mono,Courier New" FontSize="11"
                 Background="#FF151515" Foreground="#FFB0E0A0" BorderBrush="#FF333333"
                 TextWrapping="NoWrap"/>

        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
            <Button Command="{Binding CopyAndOpenIssueCommand}"
                    Padding="10,6" Margin="0,0,8,0"
                    Background="#FFD4A847" BorderBrush="#FFD4A847">
                <TextBlock Text="Copy JSON + Open Issue" Foreground="#FF1A1A1A" FontWeight="SemiBold"/>
            </Button>
            <Button Content="Save to File…" Command="{Binding SaveToFileCommand}"
                    Padding="10,6"
                    Background="#FF2A2A2A" Foreground="#CCFFFFFF" BorderBrush="#FF444444"/>
        </StackPanel>

        <TextBlock Text="{Binding StatusMessage}" Foreground="#FF7AB880"
                   FontSize="{DynamicResource AppFontSizeHint}" Margin="0,8,0,0"
                   Visibility="{Binding StatusMessage, Converter={StaticResource NullOrEmptyToVis}}"/>
    </StackPanel>
</UserControl>
