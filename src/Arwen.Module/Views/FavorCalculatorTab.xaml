<UserControl x:Class="Arwen.Views.FavorCalculatorTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:domain="clr-namespace:Arwen.Domain"
             xmlns:vm="clr-namespace:Arwen.ViewModels"
             xmlns:wpf="clr-namespace:Mithril.Shared.Wpf;assembly=Mithril.Shared"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:FavorCalculatorViewModel}"
             Background="#FF1A1A1A">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Mithril.Shared;component/Wpf/Resources.xaml"/>
                <ResourceDictionary Source="Resources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left panel: NPC + preferences -->
        <StackPanel Grid.Column="0" Margin="0,0,12,0">
            <TextBlock Text="NPC" Foreground="#88FFFFFF" FontSize="{DynamicResource AppFontSizeHint}" Margin="0,0,0,4"/>
            <ComboBox ItemsSource="{Binding NpcList}" SelectedItem="{Binding SelectedNpc}"
                      DisplayMemberPath="Name" IsEditable="True" IsTextSearchEnabled="True"
                      FontSize="{DynamicResource AppFontSizeMedium}" Background="#FF2A2A2A" Foreground="#FFE8E8E8" BorderBrush="#FF444444"/>

            <TextBlock Text="Preferences" Foreground="#88FFFFFF" FontSize="{DynamicResource AppFontSizeHint}" Margin="0,12,0,4"/>
            <ItemsControl ItemsSource="{Binding NpcPreferences}" MaxHeight="300">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#88FFFFFF"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Desire}" Value="Love">
                                                <Setter Property="Fill" Value="#FFE8C97A"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Desire}" Value="Like">
                                                <Setter Property="Fill" Value="#FF7AB880"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Desire}" Value="Hate">
                                                <Setter Property="Fill" Value="#FFE07070"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding Name}" Foreground="#CCFFFFFF" FontSize="{DynamicResource AppFontSize}"/>
                            <TextBlock Text="{Binding Pref, StringFormat=' ({0:+0.#;-0.#})'}"
                                       Foreground="#88FFFFFF" FontSize="{DynamicResource AppFontSizeHint}" Margin="4,0,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Target tier -->
            <TextBlock Text="Target Tier" Foreground="#88FFFFFF" FontSize="{DynamicResource AppFontSizeHint}" Margin="0,16,0,4"/>
            <ComboBox ItemsSource="{Binding Source={x:Static domain:FavorTiers.TargetTierOptions}}"
                      SelectedItem="{Binding TargetTier}"
                      FontSize="{DynamicResource AppFontSizeMedium}" Background="#FF2A2A2A" Foreground="#FFE8E8E8" BorderBrush="#FF444444">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource TierToDisplayNameConverter}}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- Result -->
            <Border Background="#FF252525" CornerRadius="4" Padding="12" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="{Binding ResultText}" Foreground="#FFD4A847" FontSize="{DynamicResource AppFontSizeLarge}" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding BreakdownText}" Foreground="#88FFFFFF" FontSize="{DynamicResource AppFontSizeHint}"
                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Right panel: Item search + matching items -->
        <DockPanel Grid.Column="1">
            <TextBlock DockPanel.Dock="Top" Text="Matching Items" Foreground="#88FFFFFF" FontSize="{DynamicResource AppFontSizeHint}" Margin="0,0,0,4"/>
            <TextBox DockPanel.Dock="Top"
                     Text="{Binding ItemSearchText, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="{DynamicResource AppFontSizeMedium}" Padding="6,4" Margin="0,0,0,8"
                     Background="#FF2A2A2A" Foreground="#FFE8E8E8" BorderBrush="#FF444444"/>

            <wpf:MithrilDataGrid ItemsSource="{Binding MatchingItems}" SelectedItem="{Binding SelectedItem}"
                                Mode="ReadOnly" CanUserResizeRows="False">
                <wpf:MithrilDataGrid.Columns>
                    <DataGridTemplateColumn Header="Item" Width="*" SortMemberPath="ItemName">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <wpf:IconNameCell IconId="{Binding IconId}" DisplayName="{Binding ItemName}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Desire" Binding="{Binding Desire}" Width="70">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#CCFFFFFF"/>
                                <Setter Property="Padding" Value="6,4"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Pref" Binding="{Binding Pref, StringFormat=+0.#;-0.#}" Width="55">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#FFD4A847"/>
                                <Setter Property="Padding" Value="6,4"/>
                                <Setter Property="TextAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Value" Binding="{Binding ItemValue, StringFormat=N0}" Width="70">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#CCFFFFFF"/>
                                <Setter Property="Padding" Value="6,4"/>
                                <Setter Property="TextAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Keyword" Binding="{Binding MatchedKeyword}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#88FFFFFF"/>
                                <Setter Property="Padding" Value="6,4"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </wpf:MithrilDataGrid.Columns>
            </wpf:MithrilDataGrid>
        </DockPanel>
    </Grid>
</UserControl>
