<UserControl x:Class="Arwen.Views.GiftScannerTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Arwen.ViewModels"
             xmlns:wpf="clr-namespace:Gorgon.Shared.Wpf;assembly=Gorgon.Shared"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:GiftScannerViewModel}"
             Background="#FF1A1A1A">

    <DockPanel Margin="12">
        <!-- Header controls -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="NPC" Foreground="#88FFFFFF" FontSize="{DynamicResource AppFontSizeHint}" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding NpcList}" SelectedItem="{Binding SelectedNpc}"
                              DisplayMemberPath="Name" IsEditable="True" IsTextSearchEnabled="True"
                              Width="220" FontSize="{DynamicResource AppFontSizeMedium}"
                              Background="#FF2A2A2A" Foreground="#FFE8E8E8" BorderBrush="#FF444444"/>
                </StackPanel>
                <StackPanel VerticalAlignment="Bottom">
                    <TextBlock Text="Storage" Foreground="#88FFFFFF" FontSize="{DynamicResource AppFontSizeHint}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding ActiveCharacterLabel, TargetNullValue='(no active character)'}"
                               Foreground="#FFE8E8E8" FontSize="{DynamicResource AppFontSizeMedium}"
                               VerticalAlignment="Center"
                               ToolTip="Switch the active character from the shell header."/>
                </StackPanel>
            </StackPanel>
            <TextBlock Text="{Binding StatusMessage}" Foreground="#88FFFFFF" FontSize="{DynamicResource AppFontSize}" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Filter row -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Filter" Foreground="#88FFFFFF" FontSize="{DynamicResource AppFontSizeHint}"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <wpf:GorgonQueryBox Grid.Column="1"
                                    Grid="{Binding ElementName=ResultsGrid}"
                                    QueryText="{Binding ElementName=ResultsGrid, Path=QueryText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Watermark="type text, or grammar like Desire = 'Love' AND Score > 0"/>
            </Grid>
            <TextBlock Text="{Binding ElementName=ResultsGrid, Path=QueryError}"
                       Foreground="#FFCC6666" FontSize="{DynamicResource AppFontSizeHint}" Margin="0,4,0,0"
                       Visibility="{Binding ElementName=ResultsGrid, Path=QueryError,
                           Converter={StaticResource NullOrEmptyToVis}}"/>
        </StackPanel>

        <!-- Results grid -->
        <wpf:GorgonDataGrid x:Name="ResultsGrid" ItemsSource="{Binding Results}"
                            Mode="ReadOnly" CanUserResizeRows="False"
                            Margin="0,4,0,0">
            <wpf:GorgonDataGrid.Columns>
                <DataGridTemplateColumn Header="Item" Width="*" SortMemberPath="ItemName">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <wpf:IconNameCell IconId="{Binding IconId}" DisplayName="{Binding ItemName}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Stack" Binding="{Binding StackSize}" Width="60">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#CCFFFFFF"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="TextAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTemplateColumn Header="Desire" Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Desire}" Padding="6,4">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#CCFFFFFF"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Desire}" Value="Love">
                                                <Setter Property="Foreground" Value="#FFE8C97A"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Desire}" Value="Like">
                                                <Setter Property="Foreground" Value="#FF7AB880"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Desire}" Value="Hate">
                                                <Setter Property="Foreground" Value="#FFE07070"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Pref" Binding="{Binding Pref, StringFormat=+0.#;-0.#}" Width="55">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FFD4A847"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="TextAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Value" Binding="{Binding ItemValue, StringFormat=N0}" Width="70">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#CCFFFFFF"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="TextAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Est. Favor" Binding="{Binding EstimatedFavor, StringFormat=~{0:N0}, TargetNullValue='—'}" Width="90">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FF7AB880"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="TextAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTemplateColumn Header="Src" Width="64" SortMemberPath="EstimateSource">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Margin="4,3" Padding="5,1" CornerRadius="3" HorizontalAlignment="Left"
                                    Visibility="{Binding EstimateSource, Converter={StaticResource NullOrEmptyToVis}}"
                                    ToolTip="{Binding EstimateSamples, StringFormat='{}{0} sample(s)'}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#FF333333"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding EstimateSource}" Value="Item">
                                                <Setter Property="Background" Value="#FF3F5A2E"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding EstimateSource}" Value="Signature">
                                                <Setter Property="Background" Value="#FF3E4B66"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding EstimateSource}" Value="NPC">
                                                <Setter Property="Background" Value="#FF5E4A28"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding EstimateSource}" Value="Global">
                                                <Setter Property="Background" Value="#FF4A4A4A"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding EstimateSource}" Foreground="#FFE8E8E8"
                                           FontSize="10" FontWeight="SemiBold"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Favor After Gift" Width="220">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Margin="6,3">
                                <Grid Height="14">
                                    <Border Background="#FF333333" CornerRadius="3"/>
                                    <!-- Projected favor (green, drawn under current) -->
                                    <Border Background="#FF7AB880" CornerRadius="3"
                                            HorizontalAlignment="Left"
                                            Width="{Binding ProjectedProgressFraction,
                                                Converter={StaticResource ProgressToWidthConverter},
                                                ConverterParameter=200,
                                                FallbackValue=0}"/>
                                    <!-- Current favor (gold, drawn on top) -->
                                    <Border Background="#FFD4A847" CornerRadius="3"
                                            HorizontalAlignment="Left"
                                            Width="{Binding CurrentProgressFraction,
                                                Converter={StaticResource ProgressToWidthConverter},
                                                ConverterParameter=200,
                                                FallbackValue=0}"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding CurrentFavor, StringFormat=F0, TargetNullValue='?'}"
                                               Foreground="#FFD4A847" FontSize="10"/>
                                    <TextBlock Text=" → " Foreground="#88FFFFFF" FontSize="10"/>
                                    <TextBlock Text="{Binding ProjectedFavor, StringFormat=F0, TargetNullValue='?'}"
                                               Foreground="#FF7AB880" FontSize="10"/>
                                    <TextBlock Text="  /  " Foreground="#88FFFFFF" FontSize="10"/>
                                    <TextBlock Text="{Binding CurrentTierCeiling, StringFormat=F0}"
                                               Foreground="#88FFFFFF" FontSize="10"/>
                                    <TextBlock Text=" (" Foreground="#88FFFFFF" FontSize="10"/>
                                    <TextBlock Text="{Binding ProjectedTier, Converter={StaticResource TierToDisplayNameConverter}}"
                                               Foreground="#88FFFFFF" FontSize="10"/>
                                    <TextBlock Text=")" Foreground="#88FFFFFF" FontSize="10"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Score" Binding="{Binding RelativeScore, StringFormat=N0}" Width="90">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FFD4A847"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="TextAlignment" Value="Right"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="160">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#88FFFFFF"/>
                            <Setter Property="Padding" Value="6,4"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </wpf:GorgonDataGrid.Columns>
            <wpf:GorgonDataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource GorgonDataGridRowStyle}">
                    <Setter Property="ToolTip">
                        <Setter.Value>
                            <ToolTip Background="Transparent" BorderThickness="0" Padding="0"
                                     Content="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <ToolTip.ContentTemplate>
                                    <DataTemplate>
                                        <Border Background="#FF2A2A2A" BorderBrush="#55FFFFFF" BorderThickness="1"
                                                CornerRadius="4" Padding="10" MaxWidth="320">
                                            <DockPanel>
                                                <wpf:IconImage DockPanel.Dock="Left" IconId="{Binding IconId}"
                                                               Width="40" Height="40" Margin="0,0,10,0" VerticalAlignment="Top"/>
                                                <TextBlock Text="{Binding ItemName}" FontWeight="Bold"
                                                           Foreground="#FFD4A847" FontSize="{DynamicResource AppFontSizeLarge}" TextWrapping="Wrap"
                                                           VerticalAlignment="Center"/>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ToolTip.ContentTemplate>
                            </ToolTip>
                        </Setter.Value>
                    </Setter>
                </Style>
            </wpf:GorgonDataGrid.RowStyle>
        </wpf:GorgonDataGrid>
    </DockPanel>
</UserControl>
