<UserControl x:Class="Arwen.Views.GiftScannerTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Arwen.ViewModels"
             xmlns:wpf="clr-namespace:Gorgon.Shared.Wpf;assembly=Gorgon.Shared"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:GiftScannerViewModel}"
             Background="#FF1A1A1A">

    <DockPanel Margin="12">
        <!-- Header controls -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="NPC" Foreground="#88FFFFFF" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding NpcList}" SelectedItem="{Binding SelectedNpc}"
                              DisplayMemberPath="Name" IsEditable="True" IsTextSearchEnabled="True"
                              Width="220" FontSize="13"
                              Background="#FF2A2A2A" Foreground="#FFE8E8E8" BorderBrush="#FF444444"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Storage Export" Foreground="#88FFFFFF" FontSize="11" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal">
                        <ComboBox ItemsSource="{Binding AvailableReports}" SelectedItem="{Binding SelectedReport}"
                                  Width="260" FontSize="13"
                                  Background="#FF2A2A2A" Foreground="#FFE8E8E8" BorderBrush="#FF444444"/>
                        <Button Content="Refresh" Command="{Binding RefreshReportsCommand}"
                                Margin="6,0,0,0" Padding="10,4" FontSize="12"/>
                        <CheckBox Content="Show all snapshots" IsChecked="{Binding ShowAllReports}"
                                  Margin="10,0,0,0" VerticalAlignment="Center"
                                  Foreground="#CCFFFFFF" FontSize="12"
                                  ToolTip="When unchecked, only the newest storage export per character is shown."/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            <TextBlock Text="{Binding StatusMessage}" Foreground="#88FFFFFF" FontSize="12" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Results grid -->
        <DataGrid ItemsSource="{Binding Results}" AutoGenerateColumns="False"
                  IsReadOnly="True" SelectionMode="Single" CanUserResizeRows="False"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#FF333333"
                  Background="#FF1A1A1A" RowBackground="#FF1E1E1E" AlternatingRowBackground="#FF232323"
                  BorderBrush="#FF333333" BorderThickness="1" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Item" Width="*" SortMemberPath="ItemName">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <wpf:IconNameCell IconId="{Binding IconId}" DisplayName="{Binding ItemName}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Stack" Binding="{Binding StackSize}" Width="60">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#CCFFFFFF"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="TextAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTemplateColumn Header="Desire" Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Desire}" Padding="6,4">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#CCFFFFFF"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Desire}" Value="Love">
                                                <Setter Property="Foreground" Value="#FFE8C97A"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Desire}" Value="Like">
                                                <Setter Property="Foreground" Value="#FF7AB880"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Desire}" Value="Hate">
                                                <Setter Property="Foreground" Value="#FFE07070"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Pref" Binding="{Binding Pref, StringFormat=+0.#;-0.#}" Width="55">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FFD4A847"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="TextAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Value" Binding="{Binding ItemValue, StringFormat=N0}" Width="70">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#CCFFFFFF"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="TextAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Est. Favor" Binding="{Binding EstimatedFavor, StringFormat=~{0:N0}, TargetNullValue='—'}" Width="90">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FF7AB880"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="TextAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Score" Binding="{Binding RelativeScore, StringFormat=N0}" Width="90">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FFD4A847"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="TextAlignment" Value="Right"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="160">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#88FFFFFF"/>
                            <Setter Property="Padding" Value="6,4"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="ToolTip">
                        <Setter.Value>
                            <ToolTip Background="Transparent" BorderThickness="0" Padding="0"
                                     Content="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <ToolTip.ContentTemplate>
                                    <DataTemplate>
                                        <Border Background="#FF2A2A2A" BorderBrush="#55FFFFFF" BorderThickness="1"
                                                CornerRadius="4" Padding="10" MaxWidth="320">
                                            <DockPanel>
                                                <wpf:IconImage DockPanel.Dock="Left" IconId="{Binding IconId}"
                                                               Width="40" Height="40" Margin="0,0,10,0" VerticalAlignment="Top"/>
                                                <TextBlock Text="{Binding ItemName}" FontWeight="Bold"
                                                           Foreground="#FFD4A847" FontSize="14" TextWrapping="Wrap"
                                                           VerticalAlignment="Center"/>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ToolTip.ContentTemplate>
                            </ToolTip>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>
    </DockPanel>
</UserControl>
