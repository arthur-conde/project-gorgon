<UserControl x:Class="Arwen.Views.ItemLookupTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Arwen.ViewModels"
             xmlns:wpf="clr-namespace:Gorgon.Shared.Wpf;assembly=Gorgon.Shared"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:ItemLookupViewModel}"
             Background="#FF1A1A1A">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Gorgon.Shared;component/Wpf/Resources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel Margin="12">
        <!-- Item search -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <TextBlock Text="Item" Foreground="#88FFFFFF" FontSize="{DynamicResource AppFontSizeHint}" Margin="0,0,0,4"/>
            <ComboBox ItemsSource="{Binding MatchingItems}" SelectedItem="{Binding SelectedItem}"
                      DisplayMemberPath="Name" IsEditable="True" IsTextSearchEnabled="True"
                      Text="{Binding ItemSearchText, UpdateSourceTrigger=PropertyChanged}"
                      Width="360" HorizontalAlignment="Left" FontSize="{DynamicResource AppFontSizeMedium}"
                      Background="#FF2A2A2A" Foreground="#FFE8E8E8" BorderBrush="#FF444444"/>
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <CheckBox Content="Show all NPCs" IsChecked="{Binding ShowAllNpcs}"
                          Foreground="#CCFFFFFF" VerticalAlignment="Center" FontSize="{DynamicResource AppFontSize}"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#88FFFFFF" FontSize="{DynamicResource AppFontSize}"
                           VerticalAlignment="Center" Margin="16,0,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- NPC results filter -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Filter" Foreground="#88FFFFFF" FontSize="{DynamicResource AppFontSizeHint}"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <wpf:GorgonQueryBox Grid.Column="1"
                                    Grid="{Binding ElementName=ResultsGrid}"
                                    QueryText="{Binding ElementName=ResultsGrid, Path=QueryText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Watermark="type text, or grammar like Desire = 'Love' AND HasMet = TRUE"/>
            </Grid>
            <TextBlock Text="{Binding ElementName=ResultsGrid, Path=QueryError}"
                       Foreground="#FFCC6666" FontSize="{DynamicResource AppFontSizeHint}" Margin="0,4,0,0"
                       Visibility="{Binding ElementName=ResultsGrid, Path=QueryError,
                           Converter={StaticResource NullOrEmptyToVis}}"/>
        </StackPanel>

        <!-- NPC results -->
        <wpf:GorgonDataGrid x:Name="ResultsGrid" ItemsSource="{Binding Results}"
                            Mode="ReadOnly" CanUserResizeRows="False"
                            Margin="0,4,0,0">
            <wpf:GorgonDataGrid.Columns>
                <DataGridTemplateColumn Header="NPC" Width="170">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="6,4">
                                <Ellipse Width="7" Height="7" Margin="0,0,6,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#44FFFFFF"/>
                                            <Setter Property="ToolTip" Value="Not yet met"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasMet}" Value="True">
                                                    <Setter Property="Fill" Value="#FF7AB880"/>
                                                    <Setter Property="ToolTip" Value="Met"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{Binding NpcName}" Foreground="#FFE8E8E8" FontWeight="Medium"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Area" Binding="{Binding Area}" Width="140">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#88FFFFFF"/>
                            <Setter Property="Padding" Value="6,4"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTemplateColumn Header="Desire" Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Desire}" Padding="6,4">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#CCFFFFFF"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Desire}" Value="Love">
                                                <Setter Property="Foreground" Value="#FFE8C97A"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Desire}" Value="Like">
                                                <Setter Property="Foreground" Value="#FF7AB880"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Pref" Binding="{Binding Pref, StringFormat=+0.#;-0.#}" Width="55">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FFD4A847"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="TextAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Est. Favor" Binding="{Binding EstimatedFavor, StringFormat=~{0:F1}, TargetNullValue='—'}" Width="90">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FF7AB880"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="TextAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Your Favor" Binding="{Binding CurrentTier}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#CCFFFFFF"/>
                            <Setter Property="Padding" Value="6,4"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Keyword" Binding="{Binding MatchedKeyword}" Width="140">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#88FFFFFF"/>
                            <Setter Property="Padding" Value="6,4"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </wpf:GorgonDataGrid.Columns>
        </wpf:GorgonDataGrid>
    </DockPanel>
</UserControl>
