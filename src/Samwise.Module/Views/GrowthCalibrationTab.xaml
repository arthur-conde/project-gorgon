<UserControl x:Class="Samwise.Views.GrowthCalibrationTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Samwise.ViewModels"
             xmlns:wpf="clr-namespace:Gorgon.Shared.Wpf;assembly=Gorgon.Shared"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:GrowthCalibrationViewModel}"
             Background="#FF1A1A1A">

    <DockPanel Margin="12">
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding StatusMessage}" Foreground="#88FFFFFF" FontSize="{DynamicResource AppFontSize}"
                           VerticalAlignment="Center"/>
                <Button Content="Refresh" Command="{Binding RefreshCommand}" Margin="16,0,0,0"
                        Padding="10,3" FontSize="{DynamicResource AppFontSizeHint}"
                        Background="#FF2A2A2A" Foreground="#CCFFFFFF" BorderBrush="#FF444444"/>
            </StackPanel>
        </StackPanel>

        <!-- Crop Growth Rates -->
        <TextBlock DockPanel.Dock="Top" Text="Crop Growth Rates" Foreground="#FFD4A847" FontSize="{DynamicResource AppFontSizeMedium}"
                   FontWeight="SemiBold" Margin="0,4,0,4"/>
        <wpf:GorgonDataGrid DockPanel.Dock="Top" ItemsSource="{Binding Rates}"
                            Mode="ReadOnly"
                            CanUserResizeRows="False"
                            MaxHeight="260" Margin="0,0,0,12">
            <wpf:GorgonDataGrid.Columns>
                <DataGridTextColumn Header="Crop" Binding="{Binding CropType}" Width="130" SortMemberPath="CropType">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FFE8E8E8"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="FontWeight" Value="Medium"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Avg" Binding="{Binding AvgFormatted}" Width="80" SortMemberPath="AvgSeconds">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FFD4A847"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="TextAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Samples" Binding="{Binding SampleCount}" Width="65" SortMemberPath="SampleCount">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FF7AB880"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="TextAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Min" Binding="{Binding MinFormatted}" Width="70" SortMemberPath="MinSeconds">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#88FFFFFF"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="TextAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Max" Binding="{Binding MaxFormatted}" Width="70" SortMemberPath="MaxSeconds">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#88FFFFFF"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="TextAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Config" Binding="{Binding ConfigFormatted}" Width="70" SortMemberPath="ConfigSeconds">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#AAFFFFFF"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="TextAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Delta" Binding="{Binding DeltaLabel}" Width="100" SortMemberPath="DeltaPercent">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FFCC6666"/>
                            <Setter Property="Padding" Value="6,4"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </wpf:GorgonDataGrid.Columns>
        </wpf:GorgonDataGrid>

        <!-- Observations: single filter box — plain text does a cross-column substring
             match on string columns; grammar (detected via uppercase keywords or operator
             characters) runs through the SQL-like compiler with syntax highlighting and
             autocomplete. -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,4">
            <TextBlock Text="Observations" Foreground="#FFD4A847" FontSize="{DynamicResource AppFontSizeMedium}"
                       FontWeight="SemiBold" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Filter" Foreground="#88FFFFFF" FontSize="{DynamicResource AppFontSizeHint}"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <wpf:GorgonQueryBox Grid.Column="1"
                                    Grid="{Binding ElementName=ObservationsGrid}"
                                    QueryText="{Binding ElementName=ObservationsGrid, Path=QueryText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Watermark="type text to search string columns, or grammar like CropType LIKE '%aster%'"
                                    ToolTip="Plain text matches any text column; uppercase keywords like LIKE / AND / OR switch to the grammar compiler. Ctrl+Space for suggestions."/>
            </Grid>
            <TextBlock Text="{Binding ElementName=ObservationsGrid, Path=QueryError}"
                       Foreground="#FFCC6666" FontSize="{DynamicResource AppFontSizeHint}" Margin="0,0,0,4"
                       Visibility="{Binding ElementName=ObservationsGrid, Path=QueryError,
                           Converter={StaticResource NullOrEmptyToVis}}"/>
        </StackPanel>

        <!-- Raw observations -->
        <wpf:GorgonDataGrid x:Name="ObservationsGrid"
                            ItemsSource="{Binding Observations}"
                            Mode="ReadOnly"
                            CanUserResizeRows="False">
            <wpf:GorgonDataGrid.Columns>
                <DataGridTextColumn Header="Crop" Binding="{Binding CropType}" Width="130" SortMemberPath="CropType">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FFE8E8E8"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="FontWeight" Value="Medium"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Char" Binding="{Binding CharName}" Width="100" SortMemberPath="CharName">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#CCFFFFFF"/>
                            <Setter Property="Padding" Value="6,4"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Effective" Binding="{Binding EffectiveFormatted}" Width="80" SortMemberPath="EffectiveSeconds">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FFD4A847"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="TextAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Phases" Binding="{Binding PhaseSummary}" Width="*" SortMemberPath="PhaseSummary">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#88FFFFFF"/>
                            <Setter Property="Padding" Value="6,4"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat=yyyy-MM-dd HH:mm}" Width="130" SortMemberPath="Timestamp">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#66FFFFFF"/>
                            <Setter Property="Padding" Value="6,4"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </wpf:GorgonDataGrid.Columns>
        </wpf:GorgonDataGrid>
    </DockPanel>
</UserControl>
