<UserControl x:Class="Mithril.Shared.Wpf.Sorting.MithrilSortPopup"
             x:Name="Self"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sort="clr-namespace:Mithril.Shared.Wpf.Sorting"
             xmlns:query="clr-namespace:Mithril.Shared.Wpf.Query">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Mithril.Shared.Wpf;component/Resources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Popup x:Name="Host"
           IsOpen="{Binding IsOpen, ElementName=Self, Mode=TwoWay}"
           PlacementTarget="{Binding PlacementTarget, ElementName=Self}"
           Placement="Bottom"
           StaysOpen="False"
           AllowsTransparency="True"
           PopupAnimation="Fade"
           VerticalOffset="2">
        <Border Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource BorderStrongBrush}"
                BorderThickness="1"
                CornerRadius="3"
                Padding="10"
                MinWidth="280"
                SnapsToDevicePixels="True"
                KeyDown="OnPopupKeyDown">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2" Opacity="0.55"/>
            </Border.Effect>

            <DockPanel>
                <!-- Hint -->
                <TextBlock DockPanel.Dock="Bottom"
                           Text="Click a chip to toggle. Active chips show direction; click again to flip; click a third time to remove."
                           Foreground="{StaticResource TextTertiaryBrush}"
                           FontSize="{DynamicResource AppFontSizeSmall}"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"/>

                <!-- Chip surface — all available chips render here; active ones carry a
                     direction glyph, inactive ones read as "add" affordances. -->
                <Border BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="1"
                        CornerRadius="3"
                        Background="{StaticResource BgRecessedBrush}"
                        Padding="3"
                        MinHeight="34">
                    <ItemsControl x:Name="TagsList"
                                  KeyboardNavigation.TabNavigation="Cycle">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- One chip: a Button whose visual state differs based on IsActive.
                                     Inactive chips read as "add" (faded text + a +). Active chips
                                     show the direction glyph in the accent colour and read as
                                     "currently sorting by this". Click always routes to
                                     ToggleChip(Key.Id). -->
                                <Button Click="OnChipClick"
                                        Cursor="Hand"
                                        Margin="2"
                                        Padding="8,3"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ToolTip="Click to add / flip / remove this sort key">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="ChipBd"
                                                    CornerRadius="10"
                                                    BorderBrush="{StaticResource BorderSubtleBrush}"
                                                    BorderThickness="1"
                                                    Background="{StaticResource BgSurfaceBrush}"
                                                    Padding="{TemplateBinding Padding}"
                                                    SnapsToDevicePixels="True">
                                                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter TargetName="ChipBd" Property="Background" Value="{StaticResource BgSurfaceHoverBrush}"/>
                                                    <Setter TargetName="ChipBd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ChipBd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <!-- Active: direction glyph (▲/▼). Inactive: + sign.
                                             Default text is "+"; IsActive=True overrides to ▲ (ascending);
                                             Direction==Descending then overrides to ▼. Order of triggers
                                             matters in WPF: later triggers win. -->
                                        <TextBlock Foreground="{StaticResource AccentBrush}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,5,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="+"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Text" Value="▲"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Direction}" Value="{x:Static query:OrderDirection.Descending}">
                                                            <Setter Property="Text" Value="▼"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Key.DisplayName}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- Order index badge for multi-key sorts. Small "#N"
                                             only shown when active. -->
                                        <TextBlock Foreground="{StaticResource TextTertiaryBrush}"
                                                   FontSize="{DynamicResource AppFontSizeSmall}"
                                                   Margin="4,0,0,0"
                                                   VerticalAlignment="Bottom">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Setter Property="Text" Value=""/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Setter Property="Text" Value="{Binding DisplayOrder, StringFormat=#{0}}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </DockPanel>
        </Border>
    </Popup>
</UserControl>
