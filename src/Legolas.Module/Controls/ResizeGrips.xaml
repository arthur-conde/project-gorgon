<UserControl x:Class="Legolas.Controls.ResizeGrips"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{x:Null}">
    <UserControl.Resources>
        <Style x:Key="GripStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Rectangle Fill="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid Background="{x:Null}">
        <Grid.RowDefinitions>
            <RowDefinition Height="6" />
            <RowDefinition Height="*" />
            <RowDefinition Height="6" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="6" />
        </Grid.ColumnDefinitions>
        <Thumb Grid.Row="0" Grid.Column="0" Cursor="SizeNWSE" Tag="NW"
               Style="{StaticResource GripStyle}" DragDelta="Grip_DragDelta" />
        <Thumb Grid.Row="0" Grid.Column="1" Cursor="SizeNS" Tag="N"
               Style="{StaticResource GripStyle}" DragDelta="Grip_DragDelta" />
        <Thumb Grid.Row="0" Grid.Column="2" Cursor="SizeNESW" Tag="NE"
               Style="{StaticResource GripStyle}" DragDelta="Grip_DragDelta" />
        <Thumb Grid.Row="1" Grid.Column="0" Cursor="SizeWE" Tag="W"
               Style="{StaticResource GripStyle}" DragDelta="Grip_DragDelta" />
        <Thumb Grid.Row="1" Grid.Column="2" Cursor="SizeWE" Tag="E"
               Style="{StaticResource GripStyle}" DragDelta="Grip_DragDelta" />
        <Thumb Grid.Row="2" Grid.Column="0" Cursor="SizeNESW" Tag="SW"
               Style="{StaticResource GripStyle}" DragDelta="Grip_DragDelta" />
        <Thumb Grid.Row="2" Grid.Column="1" Cursor="SizeNS" Tag="S"
               Style="{StaticResource GripStyle}" DragDelta="Grip_DragDelta" />
        <Thumb Grid.Row="2" Grid.Column="2" Cursor="SizeNWSE" Tag="SE"
               Style="{StaticResource GripStyle}" DragDelta="Grip_DragDelta" />
    </Grid>
</UserControl>
